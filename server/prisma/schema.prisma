  createdAt      DateTime                  @default(now()) @map("created_at")
  transitions    SafetyRuleTransition[]
  signals        SafetySignal[]

  @@unique([ruleKey, version])
  @@index([ruleKey, createdAt, id])
  @@map("safety_rule_versions")
}

model SafetyRuleTransition {
  id             String            @id @default(cuid())
  ruleVersionId  String            @map("rule_version_id")
  ruleVersion    SafetyRuleVersion @relation(fields: [ruleVersionId], references: [id], onDelete: Restrict)
  fromState      SafetyRuleState    @map("from_state")
  toState        SafetyRuleState    @map("to_state")
  rolloutPercent Int               @map("rollout_percent")
  reasonCode     String            @map("reason_code")
  actorId        String            @map("actor_id")
  actor          User              @relation("SafetyRuleTransitionActor", fields: [actorId], references: [id], onDelete: Restrict)
  createdAt      DateTime          @default(now()) @map("created_at")

  @@index([ruleVersionId, createdAt, id])
  @@index([createdAt, id])
  @@map("safety_rule_transitions")
}

model SafetySignal {
  id             String                     @id @default(cuid())
  sourceKey      String                     @unique @map("source_key")
  ruleVersionId  String?                    @map("rule_version_id")
  ruleVersion    SafetyRuleVersion?         @relation(fields: [ruleVersionId], references: [id], onDelete: Restrict)
  caseId         String                     @map("case_id")
  moderationCase ModerationCase             @relation(fields: [caseId], references: [id], onDelete: Restrict)
  signalType     String                     @map("signal_type")
