generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  member
  creator
  publisher
  moderator
  admin
}

enum UserStatus {
  active
  suspended
  deleted
}

enum ProfileLane {
  maker
  publisher
  both
}

enum TaskStatus {
  draft
  open
  assigned
  in_progress
  submitted
  pending_review
  disputed
  completed
  rejected
  cancelled
}

enum TaskVisibility {
  public
  community
  invite_only
}

enum TaskProposalStatus {
  pending
  accepted
  rejected
  withdrawn
}

enum TaskSubmissionStatus {
  pending_review
  revision_requested
  stale
  disputed
  approved
  rejected
}

enum PostSource {
  post
  prompt
  tutorial
  template
  external
  asset
}

enum LedgerStatus {
  pending
  settled
  cancelled
}

enum InternalAccountingUnit {
  points
  creative_credit
  quota_unit
}

enum InternalAccountingOperationStatus {
  pending
  applied
  compensated
  failed
}

enum AccountingReconciliationStatus {
  open
  repair_pending
  resolved
  ignored
}

enum AuditActorType {
  user
  system
}

enum AdminReviewDecision {
  approve
  reject
}

enum MediaAssetPurpose {
  task_attachment
  submission_asset
  profile_portfolio
  library_asset
}

enum MediaAssetStatus {
  pending
  uploaded
  rejected
}

enum MediaAssetRelationType {
  parent
  variant
  reused_as_input
}

enum PortfolioAssetStatus {
  draft
  published
  withdrawn
  archived
}

enum MediaScanJobStatus {
  queued
  retrying
  completed
  failed
}

enum CreativeGenerationStatus {
  queued
  running
  completed
  failed
  cancelled
  review_required
}

enum ChatConversationStatus {
  active
  archived
}

enum ChatTurnStatus {
  queued
  streaming
  completed
  stopped
  interrupted
  failed
  blocked
}

enum ChatMessageRole {
  user
  assistant
}

enum ChatMessageStatus {
  complete
  streaming
  stopped
  interrupted
  failed
  blocked
}

enum CreativeQuotaReservationStatus {
  reserved
  committed
  released
}

enum CreativeCreditLedgerStatus {
  reserved
  settled
  refunded
  cancelled
}

enum CreativeProviderReplayAction {
  applied
  ignored
  rejected
  noop
}

enum CreativeGenerationMutationType {
  cancel
  retry
  manual_replay
}

enum CreativeGenerationMutationStatus {
  requested
  pending_review
  approved
  processing
  succeeded
  failed
  rejected
}

enum CreativeOutputIngestionStatus {
  pending
  claimed
  stored
  scanning
  completed
  failed
}

enum CreativeProviderCostLedgerStatus {
  reserved
  settled
  released
  reconciliation_required
}

enum CreativeProviderControlScopeType {
  global
  provider
  workspace
  model_family
}

enum CreativeProviderCircuitStatus {
  closed
  open
  half_open
}

enum CreativeProviderCircuitOutcome {
  success
  retryable_failure
  ignored_failure
}

enum CreativeProviderRetryStatus {
  scheduled
  exhausted
  cleared
}

enum CreativeProviderOperationStatus {
  queued
  running
  completed
  failed
  cancelled
  timed_out
}

enum DomainEventPublicationStatus {
  pending
  claimed
  published
  failed
}

enum DomainEventConsumptionStatus {
  pending
  processing
  retry_scheduled
  succeeded
  dead_lettered
  compensation_pending
  compensated
  compensation_failed
}

enum DomainEventAttemptStatus {
  running
  succeeded
  failed
}

enum DomainEventCompensationStatus {
  pending
  processing
  succeeded
  failed
}

enum JobRunStatus {
  queued
  running
  retry_scheduled
  dead_lettered
  succeeded
  failed
  timed_out
  cancelled
}

enum JobAttemptStatus {
  running
  succeeded
  failed
  timed_out
  cancelled
}

enum ReleaseChangeType {
  promotion
  secret_rotation
  configuration
}

enum ReleaseChangeStatus {
  pending_approval
  approved
  rejected
  deployed
  failed
  rolled_back
}

model AuditEvent {
  id                    String         @id @default(cuid())
  actorType             AuditActorType @map("actor_type")
  actorId               String?        @map("actor_id")
  action                String
  resourceType          String         @map("resource_type")
  resourceId            String?        @map("resource_id")
  metadata              Json?
  metadataSchemaVersion Int            @default(1) @map("metadata_schema_version")
  createdAt             DateTime       @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([resourceType, createdAt])
  @@map("audit_events")
}

model ReleaseChange {
  id                String              @id
  changeType        ReleaseChangeType   @map("change_type")
  status            ReleaseChangeStatus @default(pending_approval)
  sourceEnvironment String?             @map("source_environment")
  targetEnvironment String              @map("target_environment")
  artifactVersion   String              @map("artifact_version")
  rollbackVersion   String              @map("rollback_version")
  secretRef         String?             @map("secret_ref")
  secretVersion     String?             @map("secret_version")
  summary           String
  reasonCode        String              @map("reason_code")
  requestedByRef    String              @map("requested_by_ref")
  approvedByRef     String?             @map("approved_by_ref")
  appliedByRef      String?             @map("applied_by_ref")
  rolledBackByRef   String?             @map("rolled_back_by_ref")
  version           Int                 @default(1)
  requestedAt       DateTime            @default(now()) @map("requested_at")
  approvedAt        DateTime?           @map("approved_at")
  appliedAt         DateTime?           @map("applied_at")
  rolledBackAt      DateTime?           @map("rolled_back_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  evidence ReleaseEvidence[]

  @@index([status, createdAt])
  @@index([targetEnvironment, createdAt])
  @@index([changeType, createdAt])
  @@map("release_changes")
}

model ReleaseEvidence {
  id                    String   @id
  releaseChangeId       String   @map("release_change_id")
  eventType             String   @map("event_type")
  actorRef              String   @map("actor_ref")
  reasonCode            String   @map("reason_code")
  evidence              Json
  evidenceSchemaVersion Int      @default(1) @map("evidence_schema_version")
  evidenceHash          String   @map("evidence_hash")
  createdAt             DateTime @default(now()) @map("created_at")

  releaseChange ReleaseChange @relation(fields: [releaseChangeId], references: [id], onDelete: Restrict)

  @@index([releaseChangeId, createdAt])
  @@index([eventType, createdAt])
  @@map("release_evidence")
}

model SecurityEvent {
  id                   String   @id
  type                 String
  severity             String
  source               String
  clientKey            String?  @map("client_key")
  identity             String?
  method               String?
  pathname             String?
  details              Json?
  detailsSchemaVersion Int      @default(1) @map("details_schema_version")
  occurredAt           DateTime @default(now()) @map("occurred_at")
  createdAt            DateTime @default(now()) @map("created_at")

  @@index([occurredAt])
  @@index([source, occurredAt])
  @@index([severity, occurredAt])
  @@index([type, occurredAt])
  @@map("security_events")
}

model Permission {
  id                    String   @id
  module                String   @default("unclassified")
  resource              String   @default("unclassified")
  action                String   @default("unclassified")
  riskLevel             String   @default("high") @map("risk_level")
  isProtected           Boolean  @default(false) @map("is_protected")
  resourceAuthorization Boolean  @default(false) @map("resource_authorization")
  description           String?
  createdAt             DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  role         UserRole
  permissionId String   @map("permission_id")

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([role, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model SystemSetting {
  key                String   @id
  value              Json
  valueSchemaVersion Int      @default(1) @map("value_schema_version")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model OperationLease {
  key                   String    @id
  ownerId               String    @map("owner_id")
  token                 String    @unique
  metadata              Json?
  metadataSchemaVersion Int       @default(1) @map("metadata_schema_version")
  acquiredAt            DateTime  @default(now()) @map("acquired_at")
  renewedAt             DateTime? @map("renewed_at")
  expiresAt             DateTime  @map("expires_at")
  releasedAt            DateTime? @map("released_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([ownerId])
  @@index([expiresAt])
  @@map("operation_leases")
}

model DomainEventOutbox {
  id                   String   @id
  eventType            String   @map("event_type")
  eventVersion         Int      @map("event_version")
  aggregateType        String   @map("aggregate_type")
  aggregateId          String   @map("aggregate_id")
  aggregateSequence    Int      @map("aggregate_sequence")
  ownerId              String?  @map("owner_id")
  correlationId        String   @map("correlation_id")
  causationId          String?  @map("causation_id")
  idempotencyKey       String   @unique @map("idempotency_key")
  payload              Json
  payloadSchemaVersion Int      @default(1) @map("payload_schema_version")
  occurredAt           DateTime @default(now()) @map("occurred_at")
  createdAt            DateTime @default(now()) @map("created_at")

  publication   DomainEventPublication?
  inboxReceipts DomainEventConsumerInbox[]

  @@unique([aggregateType, aggregateId, aggregateSequence])
  @@index([eventType, occurredAt])
  @@index([aggregateType, aggregateId, occurredAt])
  @@index([correlationId, occurredAt])
  @@map("domain_event_outbox")
}

model DomainEventAggregateSequence {
  id              String   @id
  aggregateType   String   @map("aggregate_type")
  aggregateId     String   @map("aggregate_id")
  currentSequence Int      @default(0) @map("current_sequence")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([aggregateType, aggregateId])
  @@map("domain_event_aggregate_sequences")
}

model DomainEventPublication {
  eventId        String                       @id @map("event_id")
  status         DomainEventPublicationStatus @default(pending)
  attempts       Int                          @default(0)
  availableAt    DateTime                     @default(now()) @map("available_at")
  claimToken     String?                      @unique @map("claim_token")
  claimedBy      String?                      @map("claimed_by")
  claimExpiresAt DateTime?                    @map("claim_expires_at")
  publishedAt    DateTime?                    @map("published_at")
  lastErrorCode  String?                      @map("last_error_code")
  createdAt      DateTime                     @default(now()) @map("created_at")
  updatedAt      DateTime                     @updatedAt @map("updated_at")

  event DomainEventOutbox @relation(fields: [eventId], references: [id], onDelete: Restrict)

  @@index([status, availableAt])
  @@index([claimExpiresAt])
  @@map("domain_event_publications")
}

model DomainEventConsumerInbox {
  id                String   @id
  eventId           String   @map("event_id")
  consumerKey       String   @map("consumer_key")
  eventType         String   @map("event_type")
  eventVersion      Int      @map("event_version")
  aggregateType     String   @map("aggregate_type")
  aggregateId       String   @map("aggregate_id")
  aggregateSequence Int      @map("aggregate_sequence")
  ownerId           String?  @map("owner_id")
  correlationId     String   @map("correlation_id")
  idempotencyKey    String   @unique @map("idempotency_key")
  receivedAt        DateTime @default(now()) @map("received_at")
  createdAt         DateTime @default(now()) @map("created_at")

  event        DomainEventOutbox               @relation(fields: [eventId], references: [id], onDelete: Restrict)
  consumption  DomainEventConsumption?
  attempts     DomainEventConsumptionAttempt[]
  compensation DomainEventCompensation?

  @@unique([eventId, consumerKey])
  @@index([consumerKey, receivedAt])
  @@index([consumerKey, aggregateType, aggregateId, aggregateSequence])
  @@map("domain_event_consumer_inbox")
}

model DomainEventConsumption {
  inboxId                 String                       @id @map("inbox_id")
  status                  DomainEventConsumptionStatus @default(pending)
  attempts                Int                          @default(0)
  maxAttempts             Int                          @map("max_attempts")
  availableAt             DateTime                     @default(now()) @map("available_at")
  leaseToken              String?                      @unique @map("lease_token")
  claimedBy               String?                      @map("claimed_by")
  claimExpiresAt          DateTime?                    @map("claim_expires_at")
  lastErrorCode           String?                      @map("last_error_code")
  lastAttemptAt           DateTime?                    @map("last_attempt_at")
  succeededAt             DateTime?                    @map("succeeded_at")
  deadLetteredAt          DateTime?                    @map("dead_lettered_at")
  compensationRequestedAt DateTime?                    @map("compensation_requested_at")
  compensatedAt           DateTime?                    @map("compensated_at")
  createdAt               DateTime                     @default(now()) @map("created_at")
  updatedAt               DateTime                     @updatedAt @map("updated_at")

  inbox DomainEventConsumerInbox @relation(fields: [inboxId], references: [id], onDelete: Restrict)

  @@index([status, availableAt])
  @@index([claimExpiresAt])
  @@map("domain_event_consumptions")
}

model DomainEventConsumptionAttempt {
  id            String                   @id
  inboxId       String                   @map("inbox_id")
  attemptNumber Int                      @map("attempt_number")
  status        DomainEventAttemptStatus @default(running)
  workerId      String                   @map("worker_id")
  leaseToken    String                   @unique @map("lease_token")
  errorCode     String?                  @map("error_code")
  startedAt     DateTime                 @default(now()) @map("started_at")
  completedAt   DateTime?                @map("completed_at")
  createdAt     DateTime                 @default(now()) @map("created_at")

  inbox DomainEventConsumerInbox @relation(fields: [inboxId], references: [id], onDelete: Restrict)

  @@unique([inboxId, attemptNumber])
  @@index([status, startedAt])
  @@map("domain_event_consumption_attempts")
}

model DomainEventConsumerCursor {
  id            String   @id
  consumerKey   String   @map("consumer_key")
  aggregateType String   @map("aggregate_type")
  aggregateId   String   @map("aggregate_id")
  lastSequence  Int      @default(0) @map("last_sequence")
  lastInboxId   String?  @map("last_inbox_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([consumerKey, aggregateType, aggregateId])
  @@map("domain_event_consumer_cursors")
}

model DomainEventCompensation {
  id             String   @id
  inboxId        String   @unique @map("inbox_id")
  requestedById  String?  @map("requested_by_id")
  reasonCode     String   @map("reason_code")
  idempotencyKey String   @unique @map("idempotency_key")
  requestedAt    DateTime @default(now()) @map("requested_at")
  createdAt      DateTime @default(now()) @map("created_at")

  inbox    DomainEventConsumerInbox         @relation(fields: [inboxId], references: [id], onDelete: Restrict)
  state    DomainEventCompensationState?
  attempts DomainEventCompensationAttempt[]

  @@index([requestedById, requestedAt])
  @@map("domain_event_compensations")
}

model DomainEventCompensationState {
  compensationId String                        @id @map("compensation_id")
  status         DomainEventCompensationStatus @default(pending)
  attempts       Int                           @default(0)
  availableAt    DateTime                      @default(now()) @map("available_at")
  leaseToken     String?                       @unique @map("lease_token")
  claimedBy      String?                       @map("claimed_by")
  claimExpiresAt DateTime?                     @map("claim_expires_at")
  lastErrorCode  String?                       @map("last_error_code")
  succeededAt    DateTime?                     @map("succeeded_at")
  createdAt      DateTime                      @default(now()) @map("created_at")
  updatedAt      DateTime                      @updatedAt @map("updated_at")

  compensation DomainEventCompensation @relation(fields: [compensationId], references: [id], onDelete: Restrict)

  @@index([status, availableAt])
  @@index([claimExpiresAt])
  @@map("domain_event_compensation_states")
}

model DomainEventCompensationAttempt {
  id             String                   @id
  compensationId String                   @map("compensation_id")
  attemptNumber  Int                      @map("attempt_number")
  status         DomainEventAttemptStatus @default(running)
  workerId       String                   @map("worker_id")
  leaseToken     String                   @unique @map("lease_token")
  errorCode      String?                  @map("error_code")
  startedAt      DateTime                 @default(now()) @map("started_at")
  completedAt    DateTime?                @map("completed_at")
  createdAt      DateTime                 @default(now()) @map("created_at")

  compensation DomainEventCompensation @relation(fields: [compensationId], references: [id], onDelete: Restrict)

  @@unique([compensationId, attemptNumber])
  @@index([status, startedAt])
  @@map("domain_event_compensation_attempts")
}

model JobDefinition {
  id                    String    @id
  type                  String
  version               Int       @default(1)
  enabled               Boolean   @default(true)
  defaultTimeoutSeconds Int       @default(300) @map("default_timeout_seconds")
  maxAttempts           Int       @default(3) @map("max_attempts")
  retryBackoffSeconds   Int       @default(60) @map("retry_backoff_seconds")
  cronSchedule          String?   @map("cron_schedule")
  pausedAt              DateTime? @map("paused_at")
  description           String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  runs JobRun[]

  @@unique([type, version])
  @@map("job_definitions")
}

model JobRun {
  id                  String       @id
  definitionId        String       @map("definition_id")
  status              JobRunStatus @default(queued)
  priority            Int          @default(0)
  idempotencyKey      String       @unique @map("idempotency_key")
  ownerId             String?      @map("owner_id")
  requestedById       String?      @map("requested_by_id")
  correlationId       String       @map("correlation_id")
  input               Json?
  inputSchemaVersion  Int          @default(1) @map("input_schema_version")
  result              Json?
  resultSchemaVersion Int          @default(1) @map("result_schema_version")
  errorCode           String?      @map("error_code")
  scheduledAt         DateTime     @default(now()) @map("scheduled_at")
  startedAt           DateTime?    @map("started_at")
  heartbeatAt         DateTime?    @map("heartbeat_at")
  timeoutAt           DateTime?    @map("timeout_at")
  cancelRequestedAt   DateTime?    @map("cancel_requested_at")
  completedAt         DateTime?    @map("completed_at")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  definition JobDefinition @relation(fields: [definitionId], references: [id], onDelete: Restrict)
  attempts   JobAttempt[]

  @@index([status, scheduledAt, priority])
  @@index([definitionId, createdAt])
  @@index([ownerId, createdAt])
  @@index([correlationId, createdAt])
  @@map("job_runs")
}

model JobAttempt {
  id                  String           @id
  runId               String           @map("run_id")
  attemptNumber       Int              @map("attempt_number")
  status              JobAttemptStatus @default(running)
  workerId            String           @map("worker_id")
  leaseToken          String           @unique @map("lease_token")
  heartbeatAt         DateTime         @default(now()) @map("heartbeat_at")
  timeoutAt           DateTime         @map("timeout_at")
  result              Json?
  resultSchemaVersion Int              @default(1) @map("result_schema_version")
  errorCode           String?          @map("error_code")
  startedAt           DateTime         @default(now()) @map("started_at")
  completedAt         DateTime?        @map("completed_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  run JobRun @relation(fields: [runId], references: [id], onDelete: Restrict)

  @@unique([runId, attemptNumber])
  @@index([status, timeoutAt])
  @@index([workerId, startedAt])
  @@map("job_attempts")
}

model AdminReview {
  id                    String               @id @default(cuid())
  queue                 String
  status                String
  title                 String
  owner                 String
  note                  String
  decision              AdminReviewDecision?
  reviewedById          String?              @map("reviewed_by_id")
  reviewedAt            DateTime?            @map("reviewed_at")
  metadata              Json?
  metadataSchemaVersion Int                  @default(1) @map("metadata_schema_version")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  reviewedBy User? @relation("AdminReviewReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([queue])
  @@index([status])
  @@map("admin_reviews")
}

model User {
  id          String     @id @default(cuid())
  email       String?    @unique
  displayName String     @map("display_name")
  avatarUrl   String?    @map("avatar_url")
  role        UserRole
  status      UserStatus @default(active)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  profile                   Profile?
  authAccounts              AuthAccount[]
  refreshTokens             RefreshToken[]
  publisherTasks            Task[]                          @relation("TaskPublisher")
  assigneeTasks             Task[]                          @relation("TaskAssignee")
  taskProposals             TaskProposal[]
  taskSubmissions           TaskSubmission[]                @relation("TaskSubmissionSubmitter")
  reviewedTaskSubmissions   TaskSubmission[]                @relation("TaskSubmissionReviewer")
  authoredPosts             Post[]
  comments                  Comment[]
  postLikes                 PostLike[]
  libraryItems              LibraryItem[]
  pointLedger               PointLedger[]
  internalPointAccount      InternalPointAccount?
  accountingIssuesReviewed  AccountingReconciliationIssue[] @relation("AccountingIssueReviewer")
  adminReviews              AdminReview[]                   @relation("AdminReviewReviewer")
  mediaAssets               MediaAsset[]
  mediaAssetRelations       MediaAssetRelation[]
  notifications             Notification[]
  mediaScanJobsReviewed     MediaScanJob[]                  @relation("MediaScanJobReviewer")
  creativeGenerations       CreativeGeneration[]
  creativeQuotaWindows      CreativeQuotaWindow[]
  creativeQuotaReservations CreativeQuotaReservation[]
  creativeCreditLedger      CreativeCreditLedger[]
  chatConversations         ChatConversation[]
  chatDeletionTombstones    ChatDeletionTombstone[]
  taskSubmissionAssets      TaskSubmissionAsset[]
  creativeGenerationAssets  CreativeGenerationAsset[]
  chatTurnInputAssets       ChatTurnInputAsset[]

  @@map("users")
}

model AuthAccount {
  id             String  @id @default(cuid())
  userId         String  @map("user_id")
  provider       String
  providerUserId String  @map("provider_user_id")
  passwordHash   String? @map("password_hash")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("auth_accounts")
}

model RefreshToken {
  id                  String    @id @default(cuid())
  userId              String    @map("user_id")
  tokenHash           String    @map("token_hash")
  familyId            String    @default(cuid()) @map("family_id")
  replacedByTokenHash String?   @map("replaced_by_token_hash")
  expiresAt           DateTime  @map("expires_at")
  revokedAt           DateTime? @map("revoked_at")
  reuseDetectedAt     DateTime? @map("reuse_detected_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

model Profile {
  userId                 String      @id @map("user_id")
  handle                 String      @unique
  bio                    String?
  lane                   ProfileLane
  skills                 String[]
  languages              String[]
  portfolio              Json?
  portfolioSchemaVersion Int         @default(1) @map("portfolio_schema_version")
  stats                  Json?
  statsSchemaVersion     Int         @default(1) @map("stats_schema_version")
  metadata               Json?
  metadataSchemaVersion  Int         @default(1) @map("metadata_schema_version")

  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioAssets ProfilePortfolioAsset[]

  @@map("profiles")
}

model Task {
  id                    String         @id @default(cuid())
  title                 String
  category              String
  description           String
  acceptanceRules       String         @map("acceptance_rules")
  rewardAmount          Decimal?       @map("reward_amount")
  rewardCurrency        String?        @map("reward_currency")
  pointsReward          Int            @map("points_reward")
  status                TaskStatus
  publisherId           String         @map("publisher_id")
  assigneeId            String?        @map("assignee_id")
  visibility            TaskVisibility
  deadlineAt            DateTime?      @map("deadline_at")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  metadata              Json?
  metadataSchemaVersion Int            @default(1) @map("metadata_schema_version")

