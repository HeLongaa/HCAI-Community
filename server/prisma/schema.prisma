generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  member
  creator
  publisher
  moderator
  admin
}

enum UserStatus {
  active
  suspended
  deleted
}

enum ProfileLane {
  maker
  publisher
  both
}

enum TaskStatus {
  draft
  open
  assigned
  in_progress
  submitted
  pending_review
  disputed
  completed
  rejected
  cancelled
}

enum TaskVisibility {
  public
  community
  invite_only
}

enum TaskProposalStatus {
  pending
  accepted
  rejected
  withdrawn
}

enum TaskSubmissionStatus {
  pending_review
  revision_requested
  stale
  disputed
  approved
  rejected
}

enum PostSource {
  post
  prompt
  tutorial
  template
  external
}

enum LedgerStatus {
  pending
  settled
  cancelled
}

enum AuditActorType {
  user
  system
}

enum AdminReviewDecision {
  approve
  reject
}

enum MediaAssetPurpose {
  task_attachment
  submission_asset
  profile_portfolio
  library_asset
}

enum MediaAssetStatus {
  pending
  uploaded
  rejected
}

enum MediaScanJobStatus {
  queued
  retrying
  completed
  failed
}

enum CreativeGenerationStatus {
  queued
  running
  completed
  failed
  cancelled
  review_required
}

enum CreativeQuotaReservationStatus {
  reserved
  committed
  released
}

enum CreativeCreditLedgerStatus {
  reserved
  settled
  refunded
  cancelled
}

enum CreativeProviderReplayAction {
  applied
  ignored
  rejected
  noop
}

enum CreativeGenerationMutationType {
  cancel
  retry
  manual_replay
}

enum CreativeGenerationMutationStatus {
  requested
  pending_review
  approved
  processing
  succeeded
  failed
  rejected
}

enum CreativeOutputIngestionStatus {
  pending
  claimed
  stored
  scanning
  completed
  failed
}

enum CreativeProviderCostLedgerStatus {
  reserved
  settled
  released
  reconciliation_required
}

model AuditEvent {
  id           String         @id @default(cuid())
  actorType    AuditActorType @map("actor_type")
  actorId      String?        @map("actor_id")
  action       String
  resourceType String         @map("resource_type")
  resourceId   String?        @map("resource_id")
  metadata     Json?
  createdAt    DateTime       @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([resourceType, createdAt])
  @@map("audit_events")
}

model SecurityEvent {
  id         String   @id
  type       String
  severity   String
  source     String
  clientKey  String?  @map("client_key")
  identity   String?
  method     String?
  pathname   String?
  details    Json?
  occurredAt DateTime @default(now()) @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([occurredAt])
  @@index([source, occurredAt])
  @@index([severity, occurredAt])
  @@index([type, occurredAt])
  @@map("security_events")
}

model Permission {
  id          String   @id
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  role         UserRole
  permissionId String   @map("permission_id")

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([role, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model OperationLease {
  key        String    @id
  ownerId    String    @map("owner_id")
  token      String    @unique
  metadata   Json?
  acquiredAt DateTime  @default(now()) @map("acquired_at")
  renewedAt  DateTime? @map("renewed_at")
  expiresAt  DateTime  @map("expires_at")
  releasedAt DateTime? @map("released_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([ownerId])
  @@index([expiresAt])
  @@map("operation_leases")
}

model AdminReview {
  id           String               @id @default(cuid())
  queue        String
  status       String
  title        String
  owner        String
  note         String
  decision     AdminReviewDecision?
  reviewedById String?              @map("reviewed_by_id")
  reviewedAt   DateTime?            @map("reviewed_at")
  metadata     Json?
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  reviewedBy User? @relation("AdminReviewReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([queue])
  @@index([status])
  @@map("admin_reviews")
}

model User {
  id          String     @id @default(cuid())
  email       String?    @unique
  displayName String     @map("display_name")
  avatarUrl   String?    @map("avatar_url")
  role        UserRole
  status      UserStatus @default(active)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  profile                   Profile?
  authAccounts              AuthAccount[]
  refreshTokens             RefreshToken[]
  publisherTasks            Task[]                     @relation("TaskPublisher")
  assigneeTasks             Task[]                     @relation("TaskAssignee")
  taskProposals             TaskProposal[]
  taskSubmissions           TaskSubmission[]           @relation("TaskSubmissionSubmitter")
  reviewedTaskSubmissions   TaskSubmission[]           @relation("TaskSubmissionReviewer")
  authoredPosts             Post[]
  comments                  Comment[]
  postLikes                 PostLike[]
  libraryItems              LibraryItem[]
  pointLedger               PointLedger[]
  adminReviews              AdminReview[]              @relation("AdminReviewReviewer")
  mediaAssets               MediaAsset[]
  notifications             Notification[]
  mediaScanJobsReviewed     MediaScanJob[]             @relation("MediaScanJobReviewer")
  creativeGenerations       CreativeGeneration[]
  creativeQuotaWindows      CreativeQuotaWindow[]
  creativeQuotaReservations CreativeQuotaReservation[]
  creativeCreditLedger      CreativeCreditLedger[]

  @@map("users")
}

model AuthAccount {
  id             String  @id @default(cuid())
  userId         String  @map("user_id")
  provider       String
  providerUserId String  @map("provider_user_id")
  passwordHash   String? @map("password_hash")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("auth_accounts")
}

model RefreshToken {
  id                  String    @id @default(cuid())
  userId              String    @map("user_id")
  tokenHash           String    @map("token_hash")
  familyId            String    @default(cuid()) @map("family_id")
  replacedByTokenHash String?   @map("replaced_by_token_hash")
  expiresAt           DateTime  @map("expires_at")
  revokedAt           DateTime? @map("revoked_at")
  reuseDetectedAt     DateTime? @map("reuse_detected_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

model Profile {
  userId    String      @id @map("user_id")
  handle    String      @unique
  bio       String?
  lane      ProfileLane
  skills    String[]
  languages String[]
  portfolio Json?
  stats     Json?
  metadata  Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Task {
  id              String         @id @default(cuid())
  title           String
  category        String
  description     String
  acceptanceRules String         @map("acceptance_rules")
  rewardAmount    Decimal?       @map("reward_amount")
  rewardCurrency  String?        @map("reward_currency")
  pointsReward    Int            @map("points_reward")
  status          TaskStatus
  publisherId     String         @map("publisher_id")
  assigneeId      String?        @map("assignee_id")
  visibility      TaskVisibility
  deadlineAt      DateTime?      @map("deadline_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  metadata        Json?

  publisher   User?            @relation("TaskPublisher", fields: [publisherId], references: [id], onDelete: Restrict)
  assignee    User?            @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  proposals   TaskProposal[]
  submissions TaskSubmission[]

  @@map("tasks")
}

model TaskProposal {
  id          String             @id @default(cuid())
  taskId      String             @map("task_id")
  proposerId  String             @map("proposer_id")
  coverLetter String             @map("cover_letter")
  estimate    String?
  status      TaskProposalStatus @default(pending)
  metadata    Json?
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  proposer User @relation(fields: [proposerId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([proposerId])
  @@map("task_proposals")
}

model TaskSubmission {
  id           String               @id @default(cuid())
  taskId       String               @map("task_id")
  submitterId  String               @map("submitter_id")
  content      String
  assetIds     String[]             @map("asset_ids")
  rightsNote   String               @default("") @map("rights_note")
  status       TaskSubmissionStatus @default(pending_review)
  reviewNote   String?              @map("review_note")
  reviewedById String?              @map("reviewed_by_id")
  reviewedAt   DateTime?            @map("reviewed_at")
  metadata     Json?
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  task       Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  submitter  User  @relation("TaskSubmissionSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("TaskSubmissionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
  @@index([submitterId])
  @@index([reviewedById])
  @@map("task_submissions")
}

model Post {
  id         String   @id @default(cuid())
  authorId   String   @map("author_id")
  title      String
  body       String
  category   String
  tag        String
  solved     Boolean  @default(false)
  viewsCount Int      @default(0) @map("views_count")
  likesCount Int      @default(0) @map("likes_count")
  createdAt  DateTime @default(now()) @map("created_at")
  metadata   Json?

  author   User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]
  likes    PostLike[]

  @@map("posts")
}

model Comment {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  authorId  String   @map("author_id")
  parentId  String?  @map("parent_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentTree", fields: [parentId], references: [id], onDelete: SetNull)
  replies Comment[] @relation("CommentTree")

  @@map("comments")
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("post_likes")
}

model LibraryItem {
  id         String     @id @default(cuid())
  userId     String     @map("user_id")
  sourceType PostSource @map("source_type")
  sourceId   String?    @map("source_id")
  title      String
  content    String
  metadata   Json?
  createdAt  DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("library_items")
}

model PointLedger {
  id              String       @id @default(cuid())
  userId          String       @map("user_id")
  sourceType      String       @map("source_type")
  sourceId        String?      @map("source_id")
  delta           Int
  balanceAfter    Int          @map("balance_after")
  status          LedgerStatus
  description     String?
  occurredAtLabel String?      @map("occurred_at_label")
  createdAt       DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceType, sourceId])
  @@map("point_ledger")
}

model MediaAsset {
  id          String            @id @default(cuid())
  ownerId     String            @map("owner_id")
  fileName    String            @map("file_name")
  storageKey  String            @unique @map("storage_key")
  contentType String            @map("content_type")
  sizeBytes   Int               @map("size_bytes")
  purpose     MediaAssetPurpose
  status      MediaAssetStatus  @default(pending)
  metadata    Json?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  owner    User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  scanJobs MediaScanJob[]

  @@index([ownerId])
  @@index([purpose])
  @@index([status])
  @@map("media_assets")
}

model MediaScanJob {
  id              String             @id @default(cuid())
  assetId         String             @map("asset_id")
  provider        String
  status          MediaScanJobStatus
  scanStatus      String             @map("scan_status")
  externalScanId  String?            @map("external_scan_id")
  attempts        Int                @default(1)
  requestedAt     DateTime?          @map("requested_at")
  timeoutAt       DateTime?          @map("timeout_at")
  nextRetryAt     DateTime?          @map("next_retry_at")
  callbackAt      DateTime?          @map("callback_at")
  failedAt        DateTime?          @map("failed_at")
  reviewedById    String?            @map("reviewed_by_id")
  reviewedAt      DateTime?          @map("reviewed_at")
  note            String?
  rejectionReason String?            @map("rejection_reason")
  metadata        Json?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  asset      MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  reviewedBy User?      @relation("MediaScanJobReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([assetId, createdAt])
  @@index([status, timeoutAt])
  @@index([scanStatus])
  @@index([externalScanId])
  @@map("media_scan_jobs")
}

model CreativeGeneration {
  id                  String                   @id
  actorId             String?                  @map("actor_id")
  actorHandle         String?                  @map("actor_handle")
  workspace           String
  mode                String
  providerId          String                   @map("provider_id")
  providerMode        String?                  @map("provider_mode")
  status              CreativeGenerationStatus
  promptHash          String                   @map("prompt_hash")
  promptPreview       String?                  @map("prompt_preview")
  inputAssetIds       String[]                 @map("input_asset_ids")
  parameterKeys       String[]                 @map("parameter_keys")
  outputAssetIds      String[]                 @map("output_asset_ids")
  usage               Json?
  credit              Json?
  quota               Json?
  safety              Json?
  policy              Json?
  providerRequestId   String?                  @map("provider_request_id")
  providerJobId       String?                  @map("provider_job_id")
  retryOfId           String?                  @map("retry_of_id")
  attemptNumber       Int                      @default(1) @map("attempt_number")
  errorCode           String?                  @map("error_code")
  errorMessagePreview String?                  @map("error_message_preview")
  startedAt           DateTime?                @map("started_at")
  completedAt         DateTime?                @map("completed_at")
  failedAt            DateTime?                @map("failed_at")
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")

  actor            User?                          @relation(fields: [actorId], references: [id], onDelete: SetNull)
  retryOf          CreativeGeneration?            @relation("CreativeGenerationRetries", fields: [retryOfId], references: [id], onDelete: SetNull)
  retryAttempts    CreativeGeneration[]           @relation("CreativeGenerationRetries")
  mutations        CreativeGenerationMutation[]
  providerReplays  CreativeProviderReplayLedger[]
  outputIngestions CreativeOutputIngestion[]

  @@index([actorId, createdAt])
  @@index([actorHandle, createdAt])
  @@index([workspace, createdAt])
  @@index([providerId, createdAt])
  @@index([retryOfId, attemptNumber])
  @@index([status, createdAt])
  @@map("creative_generations")
}

model CreativeGenerationMutation {
  id                 String                           @id @default(cuid())
  generationId       String                           @map("generation_id")
  type               CreativeGenerationMutationType
  status             CreativeGenerationMutationStatus
  idempotencyKey     String                           @unique @map("idempotency_key")
  requestedById      String?                          @map("requested_by_id")
  requestedByHandle  String?                          @map("requested_by_handle")
  reasonCode         String                           @map("reason_code")
  notePreview        String?                          @map("note_preview")
  reviewId           String?                          @unique @map("review_id")
  targetGenerationId String?                          @map("target_generation_id")
  safeMetadata       Json?                            @map("safe_metadata")
  result             Json?
  completedAt        DateTime?                        @map("completed_at")
  createdAt          DateTime                         @default(now()) @map("created_at")
  updatedAt          DateTime                         @updatedAt @map("updated_at")

  generation CreativeGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@index([generationId, createdAt])
  @@index([type, status, createdAt])
  @@map("creative_generation_mutations")
}

model CreativeProviderReplayLedger {
  id               String                       @id @default(cuid())
  generationId     String                       @map("generation_id")
  providerId       String                       @map("provider_id")
  providerMode     String?                      @map("provider_mode")
  providerJobId    String?                      @map("provider_job_id")
  providerEventId  String?                      @map("provider_event_id")
  sourceType       String                       @map("source_type")
  idempotencyKey   String                       @unique @map("idempotency_key")
  payloadHash      String?                      @map("payload_hash")
  previousStatus   CreativeGenerationStatus?    @map("previous_status")
  normalizedStatus CreativeGenerationStatus?    @map("normalized_status")
  action           CreativeProviderReplayAction
  reasonCode       String?                      @map("reason_code")
  sideEffectPlan   Json?                        @map("side_effect_plan")
  sideEffectResult Json?                        @map("side_effect_result")
  errorPreview     String?                      @map("error_preview")
  receivedAt       DateTime                     @default(now()) @map("received_at")
  appliedAt        DateTime?                    @map("applied_at")
  createdAt        DateTime                     @default(now()) @map("created_at")
  updatedAt        DateTime                     @updatedAt @map("updated_at")

  generation CreativeGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@unique([providerId, providerEventId])
  @@index([generationId, receivedAt])
  @@index([providerId, providerJobId, normalizedStatus])
  @@index([sourceType, action, receivedAt])
  @@map("creative_provider_replay_ledger")
}

model CreativeOutputIngestion {
  id                  String                        @id @default(cuid())
  sourceKey           String                        @unique @map("source_key")
  generationId        String                        @map("generation_id")
  providerId          String                        @map("provider_id")
  providerJobId       String?                       @map("provider_job_id")
  outputDigest        String                        @map("output_digest")
  outputIndex         Int                           @map("output_index")
  status              CreativeOutputIngestionStatus @default(pending)
  mediaAssetId        String?                       @map("media_asset_id")
  storageKey          String?                       @map("storage_key")
  detectedContentType String?                       @map("detected_content_type")
  sizeBytes           Int?                          @map("size_bytes")
  sha256              String?
  errorCode           String?                       @map("error_code")
  claimToken          String?                       @map("claim_token")
  claimedAt           DateTime?                     @map("claimed_at")
  leaseExpiresAt      DateTime?                     @map("lease_expires_at")
  completedAt         DateTime?                     @map("completed_at")
  createdAt           DateTime                      @default(now()) @map("created_at")
  updatedAt           DateTime                      @updatedAt @map("updated_at")

  generation CreativeGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@index([generationId, outputIndex])
  @@index([status, leaseExpiresAt])
  @@index([providerId, providerJobId])
  @@map("creative_output_ingestions")
}

model CreativeProviderBudgetWindow {
  id                 String   @id @default(cuid())
  budgetScope        String   @map("budget_scope")
  providerId         String   @map("provider_id")
  providerAccountRef String   @map("provider_account_ref")
  workspace          String
  currency           String
  windowStart        DateTime @map("window_start")
  windowEnd          DateTime @map("window_end")
  capMicros          BigInt   @map("cap_micros")
  reservedMicros     BigInt   @default(0) @map("reserved_micros")
  spentMicros        BigInt   @default(0) @map("spent_micros")
  releasedMicros     BigInt   @default(0) @map("released_micros")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  costLedgers CreativeProviderCostLedger[]

  @@unique([budgetScope, currency, windowStart, windowEnd])
  @@index([providerId, workspace, windowStart])
  @@map("creative_provider_budget_windows")
}

model CreativeProviderCostLedger {
  id                  String                           @id @default(cuid())
  sourceKey           String                           @unique @map("source_key")
  generationId        String                           @map("generation_id")
  budgetWindowId      String                           @map("budget_window_id")
  providerId          String                           @map("provider_id")
  providerAccountRef  String                           @map("provider_account_ref")
  providerModelId     String                           @map("provider_model_id")
  providerJobId       String?                          @map("provider_job_id")
  workspace           String
  mode                String
  currency            String
  pricingSnapshot     Json                             @map("pricing_snapshot")
  pricingSnapshotHash String                           @map("pricing_snapshot_hash")
  estimateMicros      BigInt                           @map("estimate_micros")
  reservedMicros      BigInt                           @map("reserved_micros")
  actualMicros        BigInt?                          @map("actual_micros")
  status              CreativeProviderCostLedgerStatus
  usage               Json?
  risk                Json?
  reasonCode          String?                          @map("reason_code")
  reservedAt          DateTime                         @default(now()) @map("reserved_at")
  settledAt           DateTime?                        @map("settled_at")
  releasedAt          DateTime?                        @map("released_at")
  reconciliationAt    DateTime?                        @map("reconciliation_at")
  createdAt           DateTime                         @default(now()) @map("created_at")
  updatedAt           DateTime                         @updatedAt @map("updated_at")

  budgetWindow CreativeProviderBudgetWindow @relation(fields: [budgetWindowId], references: [id], onDelete: Restrict)

  @@index([generationId, createdAt])
  @@index([budgetWindowId, status])
  @@index([providerId, workspace, status, createdAt])
  @@map("creative_provider_cost_ledgers")
}

model CreativeCreditLedger {
  id                 String                     @id @default(cuid())
  generationId       String                     @map("generation_id")
  quotaReservationId String?                    @unique @map("quota_reservation_id")
  actorId            String?                    @map("actor_id")
  actorHandle        String?                    @map("actor_handle")
  workspace          String
  mode               String
  reservationAmount  Int                        @map("reservation_amount")
  settledAmount      Int                        @default(0) @map("settled_amount")
  refundedAmount     Int                        @default(0) @map("refunded_amount")
  status             CreativeCreditLedgerStatus
  reasonCode         String?                    @map("reason_code")
  metadata           Json?
  reservedAt         DateTime                   @default(now()) @map("reserved_at")
  settledAt          DateTime?                  @map("settled_at")
  refundedAt         DateTime?                  @map("refunded_at")
  cancelledAt        DateTime?                  @map("cancelled_at")
  createdAt          DateTime                   @default(now()) @map("created_at")
  updatedAt          DateTime                   @updatedAt @map("updated_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([generationId])
  @@index([actorHandle, workspace, createdAt])
  @@index([status, createdAt])
  @@map("creative_credit_ledger")
}

model CreativeQuotaWindow {
  id            String   @id
  actorId       String?  @map("actor_id")
  actorHandle   String?  @map("actor_handle")
  workspace     String
  windowType    String   @map("window_type")
  windowStart   DateTime @map("window_start")
  windowEnd     DateTime @map("window_end")
  limitUnits    Int      @map("limit_units")
  reservedUnits Int      @default(0) @map("reserved_units")
  usedUnits     Int      @default(0) @map("used_units")
  releasedUnits Int      @default(0) @map("released_units")
  policyVersion String   @map("policy_version")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  actor        User?                      @relation(fields: [actorId], references: [id], onDelete: SetNull)
  reservations CreativeQuotaReservation[]

  @@unique([actorHandle, workspace, windowType, windowStart])
  @@index([actorId, windowStart])
  @@index([actorHandle, workspace, windowStart])
  @@index([workspace, windowStart])
  @@map("creative_quota_windows")
}

model CreativeQuotaReservation {
  id            String                         @id @default(cuid())
  quotaWindowId String                         @map("quota_window_id")
  generationId  String                         @map("generation_id")
  actorId       String?                        @map("actor_id")
  actorHandle   String?                        @map("actor_handle")
  workspace     String
  units         Int
  status        CreativeQuotaReservationStatus
  reason        String?
  reservedAt    DateTime                       @default(now()) @map("reserved_at")
  committedAt   DateTime?                      @map("committed_at")
  releasedAt    DateTime?                      @map("released_at")
  createdAt     DateTime                       @default(now()) @map("created_at")
  updatedAt     DateTime                       @updatedAt @map("updated_at")

  quotaWindow CreativeQuotaWindow @relation(fields: [quotaWindowId], references: [id], onDelete: Cascade)
  actor       User?               @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([generationId])
  @@index([actorHandle, workspace, createdAt])
  @@index([quotaWindowId, status])
  @@map("creative_quota_reservations")
}

model Notification {
  id           String    @id @default(cuid())
  recipientId  String    @map("recipient_id")
  type         String
  title        String
  body         String
  resourceType String    @map("resource_type")
  resourceId   String?   @map("resource_id")
  metadata     Json?
  readAt       DateTime? @map("read_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  recipient User @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, readAt, createdAt])
  @@index([type])
  @@map("notifications")
}
