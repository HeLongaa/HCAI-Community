  score          Int
  contentHash    String                     @map("content_hash")
  observedAt     DateTime                   @map("observed_at")
  createdById    String                     @map("created_by_id")
  createdBy      User                       @relation("SafetySignalCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt      DateTime                   @default(now()) @map("created_at")

  @@index([caseId, createdAt, id])
  @@index([signalType, observedAt, id])
  @@map("safety_signals")
}

model ModerationQueueEvent {
  id             String                    @id @default(cuid())
  caseId         String                    @map("case_id")
