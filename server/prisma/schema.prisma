model NotificationChannelConfigRevision {
  id                            String   @id @default(cuid())
  configId                      String   @map("config_id")
  channel                       String
  revisionNumber                Int      @map("revision_number")
  enabled                       Boolean
  deliveryRateTargetBps         Int      @map("delivery_rate_target_bps")
  failureRateAlertThresholdBps  Int      @map("failure_rate_alert_threshold_bps")
  latencyTargetMs               Int      @map("latency_target_ms")
  maxAttempts                   Int      @map("max_attempts")
