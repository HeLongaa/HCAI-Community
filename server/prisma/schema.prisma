model AuditEvent {
  id                    String         @id @default(cuid())
  actorType             AuditActorType @map("actor_type")
  actorId               String?        @map("actor_id")
  action                String
  resourceType          String         @map("resource_type")
  resourceId            String?        @map("resource_id")
  metadata              Json?
  metadataSchemaVersion Int            @default(1) @map("metadata_schema_version")
  createdAt             DateTime       @default(now()) @map("created_at")
  sequence              BigInt?        @unique
  previousHash          String?        @map("previous_hash")
  contentHash           String?        @unique @map("content_hash")
  chainVersion          Int            @default(1) @map("chain_version")

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([resourceType, createdAt])
  @@map("audit_events")
}

model AuditArchiveManifest {
  id           String   @id
  fromSequence BigInt   @map("from_sequence")
  toSequence   BigInt   @map("to_sequence")
  eventCount   Int      @map("event_count")
  rootHash     String   @map("root_hash")
  objectRef    String   @map("object_ref")
  actorId      String?  @map("actor_id")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("audit_archive_manifests")
}

model AuditRetentionDisposition {
  id                    String   @id
  policyVersion         String   @map("policy_version")
  cutoffAt              DateTime @map("cutoff_at")
  fromSequence          BigInt   @map("from_sequence")
  toSequence            BigInt   @map("to_sequence")
  eventCount            Int      @map("event_count")
  rootHash              String   @map("root_hash")
  archiveObjectRef      String   @map("archive_object_ref")
  archiveChecksumSha256 String   @map("archive_checksum_sha256")
  archiveBytes          Int      @map("archive_bytes")
  archiveProvider       String   @map("archive_provider")
  actorId               String?  @map("actor_id")
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("audit_retention_dispositions")
}

model ObservabilityLog {
  id                      String   @id
  timestamp               DateTime @default(now())
  level                   String
  service                 String
  environment             String
  event                   String
  requestId               String   @map("request_id")
  traceId                 String   @map("trace_id")
  spanId                  String   @map("span_id")
  parentSpanId            String?  @map("parent_span_id")
  module                  String
  operation               String
  outcome                 String
  durationMs              Int?     @map("duration_ms")
  errorCode               String?  @map("error_code")
  method                  String?
  routeTemplate           String?  @map("route_template")
  statusCode              Int?     @map("status_code")
  resourceType            String?  @map("resource_type")
  resourceId              String?  @map("resource_id")
  attributes              Json?
  attributesSchemaVersion Int      @default(1) @map("attributes_schema_version")

  @@index([timestamp])
  @@index([traceId, timestamp])
  @@index([requestId, timestamp])
  @@index([module, timestamp])
  @@index([level, timestamp])
  @@index([resourceType, resourceId, timestamp])
  @@map("observability_logs")
}

model TraceSpan {
  id           String   @id
  traceId      String   @map("trace_id")
  spanId       String   @unique @map("span_id")
  parentSpanId String?  @map("parent_span_id")
  requestId    String   @map("request_id")
  service      String
  module       String
  operation    String
  outcome      String
  startedAt    DateTime @map("started_at")
  endedAt      DateTime @map("ended_at")
  durationMs   Int      @map("duration_ms")
  errorCode    String?  @map("error_code")
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  jobId        String?  @map("job_id")
  eventId      String?  @map("event_id")

  @@index([traceId, startedAt])
  @@index([requestId, startedAt])
  @@index([jobId, startedAt])
  @@index([eventId, startedAt])
  @@index([startedAt])
  @@map("trace_spans")
}

model ObservabilityAlert {
  id              String    @id
  alertKey        String    @unique @map("alert_key")
  sloId           String    @map("slo_id")
  state           String
  severity        String
  shortWindowBurn Float     @map("short_window_burn")
  longWindowBurn  Float     @map("long_window_burn")
  threshold       Float
  owner           String
  runbook         String
  version         Int       @default(1)
  startedAt       DateTime  @map("started_at")
  acknowledgedAt  DateTime? @map("acknowledged_at")
  acknowledgedBy  String?   @map("acknowledged_by")
  silencedUntil   DateTime? @map("silenced_until")
  resolvedAt      DateTime? @map("resolved_at")
  resolutionNote  String?   @map("resolution_note")
  escalationLevel Int       @default(0) @map("escalation_level")
  escalatedAt     DateTime?  @map("escalated_at")
  escalatedBy     String?    @map("escalated_by")
  escalationTarget String?  @map("escalation_target")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  events ObservabilityAlertEvent[]
  review ObservabilityIncidentReview?

  @@index([state, updatedAt])
  @@index([sloId, updatedAt])
  @@map("observability_alerts")
}

model ObservabilitySloControl {
  id                       String   @id
  sloId                    String   @unique @map("slo_id")
  target                   Float
  shortWindowBurnThreshold Float    @map("short_window_burn_threshold")
  longWindowBurnThreshold  Float    @map("long_window_burn_threshold")
  latencyThresholdMs       Int      @map("latency_threshold_ms")
  severity                 String
  owner                    String
  runbook                  String
  primaryOnCallHandle      String   @map("primary_on_call_handle")
  secondaryOnCallHandle    String?  @map("secondary_on_call_handle")
  escalationMinutes        Int      @map("escalation_minutes")
  enabled                  Boolean  @default(true)
  version                  Int      @default(1)
  reasonCode               String   @map("reason_code")
  updatedBy                String   @map("updated_by")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@index([enabled, updatedAt])
  @@map("observability_slo_controls")
}

model ObservabilityAlertEvent {
  id                    String   @id
  alertId               String   @map("alert_id")
  eventType             String   @map("event_type")
  fromState             String?  @map("from_state")
  toState               String?  @map("to_state")
  reasonCode            String   @map("reason_code")
  actorRef              String   @map("actor_ref")
  metadata              Json?
  metadataSchemaVersion Int      @default(1) @map("metadata_schema_version")
  createdAt             DateTime @default(now()) @map("created_at")

  alert ObservabilityAlert @relation(fields: [alertId], references: [id], onDelete: Restrict)

  @@index([alertId, createdAt, id])
  @@index([eventType, createdAt])
  @@map("observability_alert_events")
}

model ObservabilityIncidentReview {
  id                     String   @id
  alertId                String   @unique @map("alert_id")
  summary                String
  rootCause              String   @map("root_cause")
  impact                 String
  correctiveActions      Json     @map("corrective_actions")
  correctiveActionsSchemaVersion Int @default(1) @map("corrective_actions_schema_version")
  correctiveActionsHash  String   @map("corrective_actions_hash")
  reviewerRef            String   @map("reviewer_ref")
  createdAt              DateTime @default(now()) @map("created_at")

  alert ObservabilityAlert @relation(fields: [alertId], references: [id], onDelete: Restrict)

  @@index([createdAt])
  @@map("observability_incident_reviews")
}

model ReleaseChange {
  id                String              @id
  changeType        ReleaseChangeType   @map("change_type")
  status            ReleaseChangeStatus @default(pending_approval)
  sourceEnvironment String?             @map("source_environment")
  targetEnvironment String              @map("target_environment")
  artifactVersion   String              @map("artifact_version")
  rollbackVersion   String              @map("rollback_version")
  secretRef         String?             @map("secret_ref")
  secretVersion     String?             @map("secret_version")
  summary           String
  reasonCode        String              @map("reason_code")
  requestedByRef    String              @map("requested_by_ref")
  approvedByRef     String?             @map("approved_by_ref")
  appliedByRef      String?             @map("applied_by_ref")
  rolledBackByRef   String?             @map("rolled_back_by_ref")
  version           Int                 @default(1)
  requestedAt       DateTime            @default(now()) @map("requested_at")
  approvedAt        DateTime?           @map("approved_at")
  appliedAt         DateTime?           @map("applied_at")
  rolledBackAt      DateTime?           @map("rolled_back_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  evidence       ReleaseEvidence[]
  modelPromotion ModelPromotion?

  @@index([status, createdAt])
  @@index([targetEnvironment, createdAt])
  @@index([changeType, createdAt])
  @@map("release_changes")
}

model ReleaseEvidence {
  id                    String   @id
  releaseChangeId       String   @map("release_change_id")
  eventType             String   @map("event_type")
  actorRef              String   @map("actor_ref")
  reasonCode            String   @map("reason_code")
  evidence              Json
  evidenceSchemaVersion Int      @default(1) @map("evidence_schema_version")
  evidenceHash          String   @map("evidence_hash")
  createdAt             DateTime @default(now()) @map("created_at")

  releaseChange ReleaseChange @relation(fields: [releaseChangeId], references: [id], onDelete: Restrict)

  @@index([releaseChangeId, createdAt])
  @@index([eventType, createdAt])
  @@map("release_evidence")
}

model SecurityEvent {
  id                   String   @id
  type                 String
  severity             String
  source               String
  clientKey            String?  @map("client_key")
  identity             String?
  method               String?
  pathname             String?
  details              Json?
  detailsSchemaVersion Int      @default(1) @map("details_schema_version")
  occurredAt           DateTime @default(now()) @map("occurred_at")
  createdAt            DateTime @default(now()) @map("created_at")

  @@index([occurredAt])
  @@index([source, occurredAt])
  @@index([severity, occurredAt])
  @@index([type, occurredAt])
  @@map("security_events")
}

model Permission {
  id                    String   @id
  module                String   @default("unclassified")
  resource              String   @default("unclassified")
  action                String   @default("unclassified")
  riskLevel             String   @default("high") @map("risk_level")
  isProtected           Boolean  @default(false) @map("is_protected")
  resourceAuthorization Boolean  @default(false) @map("resource_authorization")
  description           String?
  createdAt             DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  role         UserRole
  permissionId String   @map("permission_id")

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([role, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model SystemSetting {
  key                String   @id
  value              Json
  valueSchemaVersion Int      @default(1) @map("value_schema_version")
  publishedVersion   Int      @default(1) @map("published_version")
  currentRevisionId  String?  @map("current_revision_id")
  updatedAt          DateTime @updatedAt @map("updated_at")

  currentRevision SystemSettingRevision? @relation("CurrentSystemSettingRevision", fields: [currentRevisionId], references: [id], onDelete: Restrict)

  @@map("system_settings")
}

model SystemSettingChange {
  id                          String                    @id
  settingKey                  String                    @map("setting_key")
  kind                        SystemSettingChangeKind
  status                      SystemSettingChangeStatus @default(pending_approval)
  baseVersion                 Int                       @map("base_version")
  candidateValue              Json                      @map("candidate_value")
  candidateValueSchemaVersion Int                       @default(1) @map("candidate_value_schema_version")
  diff                        Json
  diffSchemaVersion           Int                       @default(1) @map("diff_schema_version")
  targetRevisionId            String?                   @map("target_revision_id")
  requestedByRef              String                    @map("requested_by_ref")
  approvedByRef               String?                   @map("approved_by_ref")
  rejectedByRef               String?                   @map("rejected_by_ref")
  publishedByRef              String?                   @map("published_by_ref")
  reasonCode                  String                    @map("reason_code")
  note                        String?
  version                     Int                       @default(1)
  requestedAt                 DateTime                  @default(now()) @map("requested_at")
  approvedAt                  DateTime?                 @map("approved_at")
  rejectedAt                  DateTime?                 @map("rejected_at")
  publishedAt                 DateTime?                 @map("published_at")
  createdAt                   DateTime                  @default(now()) @map("created_at")
  updatedAt                   DateTime                  @updatedAt @map("updated_at")

  targetRevision SystemSettingRevision?  @relation("RollbackTargetRevision", fields: [targetRevisionId], references: [id], onDelete: Restrict)
  revisions      SystemSettingRevision[]

  @@index([settingKey, createdAt])
  @@index([status, createdAt])
  @@index([requestedByRef, createdAt])
  @@index([targetRevisionId])
  @@map("system_setting_changes")
}

model SystemSettingRevision {
  id                 String   @id
  settingKey         String   @map("setting_key")
  settingVersion     Int      @map("setting_version")
  value              Json
  valueSchemaVersion Int      @default(1) @map("value_schema_version")
  previousRevisionId String?  @map("previous_revision_id")
  sourceChangeId     String   @map("source_change_id")
  eventType          String   @map("event_type")
  contentHash        String   @map("content_hash")
  actorRef           String   @map("actor_ref")
  createdAt          DateTime @default(now()) @map("created_at")

  sourceChange       SystemSettingChange     @relation(fields: [sourceChangeId], references: [id], onDelete: Restrict)
  previousRevision   SystemSettingRevision?  @relation("SystemSettingRevisionChain", fields: [previousRevisionId], references: [id], onDelete: Restrict)
  nextRevisions      SystemSettingRevision[] @relation("SystemSettingRevisionChain")
  currentForSettings SystemSetting[]         @relation("CurrentSystemSettingRevision")
  rollbackChanges    SystemSettingChange[]   @relation("RollbackTargetRevision")

  @@unique([settingKey, settingVersion])
  @@index([settingKey, createdAt])
  @@index([sourceChangeId])
  @@index([previousRevisionId])
  @@map("system_setting_revisions")
}

model ConfigResource {
  id                          String             @id
  kind                        ConfigResourceKind
  key                         String
  title                       String
  description                 String?
  draftValue                  Json               @map("draft_value")
  draftValueSchemaVersion     Int                @default(1) @map("draft_value_schema_version")
  publishedValue              Json?              @map("published_value")
  publishedValueSchemaVersion Int                @default(1) @map("published_value_schema_version")
  publishedVersion            Int                @default(0) @map("published_version")
  currentRevisionId           String?            @map("current_revision_id")
  version                     Int                @default(1)
  createdByRef                String             @map("created_by_ref")
  updatedByRef                String             @map("updated_by_ref")
  deletedByRef                String?            @map("deleted_by_ref")
  deletedAt                   DateTime?          @map("deleted_at")
  createdAt                   DateTime           @default(now()) @map("created_at")
  updatedAt                   DateTime           @updatedAt @map("updated_at")

  currentRevision ConfigResourceRevision?  @relation("CurrentConfigResourceRevision", fields: [currentRevisionId], references: [id], onDelete: Restrict)
  revisions       ConfigResourceRevision[] @relation("ConfigResourceRevisions")
  featureFlag     FeatureFlag?
  referenceData   ReferenceDataEntry?
  announcement    Announcement?
  taskRule        TaskRule?

  @@unique([kind, key])
  @@index([kind, deletedAt, updatedAt])
  @@index([currentRevisionId])
  @@map("config_resources")
}

model ConfigResourceRevision {
  id                 String   @id
  resourceId         String   @map("resource_id")
  resourceVersion    Int      @map("resource_version")
  title              String
  description        String?
  value              Json
  valueSchemaVersion Int      @default(1) @map("value_schema_version")
  previousRevisionId String?  @map("previous_revision_id")
  eventType          String   @map("event_type")
  contentHash        String   @map("content_hash")
  actorRef           String   @map("actor_ref")
  reasonCode         String   @map("reason_code")
  createdAt          DateTime @default(now()) @map("created_at")

  resource            ConfigResource           @relation("ConfigResourceRevisions", fields: [resourceId], references: [id], onDelete: Restrict)
  previousRevision    ConfigResourceRevision?  @relation("ConfigResourceRevisionChain", fields: [previousRevisionId], references: [id], onDelete: Restrict)
  nextRevisions       ConfigResourceRevision[] @relation("ConfigResourceRevisionChain")
  currentForResources ConfigResource[]         @relation("CurrentConfigResourceRevision")

  @@unique([resourceId, resourceVersion])
  @@index([resourceId, createdAt])
  @@index([previousRevisionId])
  @@map("config_resource_revisions")
}

model FeatureFlag {
  resourceId             String    @id @map("resource_id")
  key                    String    @unique
  enabled                Boolean
  payload                Json
  rules                  Json
  rulesSchemaVersion     Int       @default(1) @map("rules_schema_version")
  rolloutPercentage      Int?      @map("rollout_percentage")
  rolloutSeed            String    @map("rollout_seed")
  emergencyOff           Boolean   @default(false) @map("emergency_off")
  emergencyOffByRef      String?   @map("emergency_off_by_ref")
  emergencyOffReasonCode String?   @map("emergency_off_reason_code")
  emergencyOffAt         DateTime? @map("emergency_off_at")
  payloadSchemaVersion   Int       @default(1) @map("payload_schema_version")
  publishedVersion       Int       @map("published_version")
  deletedAt              DateTime? @map("deleted_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  resource ConfigResource @relation(fields: [resourceId], references: [id], onDelete: Restrict)

  @@map("feature_flags")
}

model ReferenceDataEntry {
  resourceId         String    @id @map("resource_id")
  key                String    @unique
  label              String
  value              Json
  valueSchemaVersion Int       @default(1) @map("value_schema_version")
  sortOrder          Int       @default(0) @map("sort_order")
