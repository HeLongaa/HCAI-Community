  moderationCase ModerationCase @relation(fields: [caseId], references: [id], onDelete: Restrict)
  reporter       User           @relation("ModerationReportReporter", fields: [reporterId], references: [id], onDelete: Restrict)

  @@index([reporterId, createdAt, id])
  @@index([category, createdAt, id])
  @@map("trust_reports")
}

model ModerationCase {
  id             String                 @id @default(cuid())
  targetType     ModerationTargetType   @map("target_type")
  targetId       String                 @map("target_id")
  affectedUserId String?                @map("affected_user_id")
