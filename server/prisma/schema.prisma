}

model SafetyRuleVersion {
  id             String                    @id @default(cuid())
  ruleKey        String                    @map("rule_key")
  version        Int
  name           String
  signalType     String                    @map("signal_type")
  targetType     ModerationTargetType?     @map("target_type")
  category       ModerationReportCategory?
  minimumScore   Int                       @map("minimum_score")
  priority       ModerationCasePriority
  configHash     String                    @map("config_hash")
