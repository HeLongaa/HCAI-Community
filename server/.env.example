NODE_ENV=development
PORT=8787

# Required in production. Use a random value with at least 32 characters.
ACCESS_TOKEN_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_KEY_ID=2026-06

# Optional. Defaults to true in production. Set true locally when testing HTTPS cookie behavior.
# AUTH_COOKIE_SECURE=true
# Optional. Use None for cross-site frontend/API deployments; this forces Secure cookies.
# AUTH_COOKIE_SAMESITE=Lax
# Optional. Share cookies across subdomains, for example .example.com.
# AUTH_COOKIE_DOMAIN=
# Optional. Comma-separated trusted browser origins allowed for credentialed CORS and cookie CSRF checks.
# AUTH_TRUSTED_ORIGINS=http://127.0.0.1:5174,https://app.example.com

# Optional during secret rotation. Keep ids aligned by position with secrets.
# ACCESS_TOKEN_PREVIOUS_SECRETS=previous-secret-one,previous-secret-two
# ACCESS_TOKEN_PREVIOUS_KEY_IDS=2026-05,2026-04

# Optional. When DATABASE_URL is omitted, the server uses the seed fallback repository.
# DATABASE_URL=postgresql://user:password@localhost:5432/hcai

# Optional abuse guard. Use RATE_LIMIT_STORE=redis for multi-instance deployments.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_STORE=memory
# RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
# RATE_LIMIT_REDIS_PREFIX=newchat:rate-limit
# RATE_LIMIT_REDIS_TIMEOUT_MS=1000
# RATE_LIMIT_REDIS_FAILURE_MODE=fail_closed
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_AUTH_MAX=120
# RATE_LIMIT_UPLOAD_MAX=120
# RATE_LIMIT_ADMIN_MUTATION_MAX=180

# Optional Prometheus-compatible metrics exporter. Keep disabled locally unless testing scrape behavior.
# If METRICS_EXPORTER_TOKEN is omitted, protect /metrics with private networking or an upstream gateway.
# METRICS_EXPORTER_ENABLED=false
# METRICS_EXPORTER_FORMAT=prometheus
# METRICS_EXPORTER_TOKEN=

# Optional request body guard. Content-Length is rejected before routing when possible;
# chunked bodies are still capped while being read.
# REQUEST_BODY_SIZE_GUARD_ENABLED=true
# REQUEST_BODY_MAX_BYTES=1048576

# Optional failed-login anomaly monitor. Emits structured events for one IP failing
# against many identities or one identity failing from many IPs.
# AUTH_FAILURE_MONITOR_ENABLED=true
# AUTH_FAILURE_WINDOW_MS=300000
# AUTH_FAILURE_IP_ACCOUNT_THRESHOLD=5
# AUTH_FAILURE_ACCOUNT_IP_THRESHOLD=5

# Optional in-process security event retention for local/test Admin security event queries.
# Prisma-backed deployments persist security events in the security_events table.
# SECURITY_EVENT_MAX_ITEMS=500
# SECURITY_ALERT_WINDOW_MINUTES=15
# SECURITY_ALERT_RATE_LIMIT_THRESHOLD=10
# SECURITY_ALERT_BODY_REJECTED_THRESHOLD=5
# SECURITY_ALERT_AUTH_FAILURE_THRESHOLD=1
# SECURITY_ALERT_WEBHOOK_URL=
# SECURITY_ALERT_WEBHOOK_SECRET=
# SECURITY_ALERT_WEBHOOK_TIMEOUT_SECONDS=5
# SECURITY_ALERT_SLACK_WEBHOOK_URL=
# SECURITY_ALERT_SLACK_TIMEOUT_SECONDS=5
# SECURITY_ALERT_EMAIL_WEBHOOK_URL=
# SECURITY_ALERT_EMAIL_WEBHOOK_SECRET=
# SECURITY_ALERT_EMAIL_TO=
# SECURITY_ALERT_EMAIL_FROM=
# SECURITY_ALERT_EMAIL_TIMEOUT_SECONDS=5

# Optional durable notification email delivery. Keep both switches false until an approved HTTPS mailer endpoint and
# signing secret are mounted. Enable the worker only in the dedicated worker process.
# NOTIFICATION_EMAIL_DELIVERY_ENABLED=false
# NOTIFICATION_EMAIL_WEBHOOK_URL=
# NOTIFICATION_EMAIL_WEBHOOK_SECRET=
# NOTIFICATION_EMAIL_FROM=
# NOTIFICATION_EMAIL_TIMEOUT_SECONDS=8
# NOTIFICATION_DELIVERY_WORKER_ENABLED=false
# NOTIFICATION_DELIVERY_WORKER_INTERVAL_SECONDS=10
# NOTIFICATION_DELIVERY_WORKER_BATCH_SIZE=25
# NOTIFICATION_DELIVERY_MAX_ATTEMPTS=3
# NOTIFICATION_DELIVERY_RETRY_BACKOFF_SECONDS=60
# NOTIFICATION_DELIVERY_LEASE_SECONDS=60

# User-managed outbound webhook delivery. The AES-256-GCM key encrypts per-subscription signing secrets at rest.
# Keep old keys in WEBHOOK_SECRET_ENCRYPTION_KEYS during key rotation until retained deliveries no longer reference them.
# WEBHOOK_SECRET_ENCRYPTION_KEY=
# WEBHOOK_SECRET_ENCRYPTION_ACTIVE_KEY_ID=v1
# WEBHOOK_SECRET_ENCRYPTION_KEYS=v1:base64-key,v2:base64-key
# WEBHOOK_DELIVERY_WORKER_ENABLED=false
# WEBHOOK_DELIVERY_WORKER_INTERVAL_SECONDS=10
# WEBHOOK_DELIVERY_WORKER_BATCH_SIZE=25
# WEBHOOK_DELIVERY_LEASE_SECONDS=60

# Optional media upload signer. Default is mock:// contracts for local development.
# Set STORAGE_DRIVER=s3 to return S3-compatible presigned PUT URLs.
# STORAGE_DRIVER=mock
# STORAGE_ENDPOINT=https://s3.amazonaws.com
# STORAGE_REGION=us-east-1
# STORAGE_BUCKET=hcai-media
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_SESSION_TOKEN=
# STORAGE_UPLOAD_TTL_SECONDS=900
# STORAGE_DOWNLOAD_TTL_SECONDS=300
# STORAGE_SCANNER_READ_TTL_SECONDS=600
# Optional private CDN download signing. Configure URL and secret together.
# STORAGE_PRIVATE_DOWNLOAD_BASE_URL=https://media.example.com
# STORAGE_PRIVATE_DOWNLOAD_SIGNING_SECRET=
# STORAGE_PRIVATE_DOWNLOAD_KEY_ID=primary

# Optional creative generation provider boundary.
# Set disabled to make generation routes report provider unavailability without exposing secrets.
# Set replicate_staging only in a dedicated staging runtime. It exposes an unavailable
# Replicate image provider shell for safe catalog/env validation. The HTTP client remains disabled by default.
# CREATIVE_PROVIDER_MODE=mock

# Optional real-provider preflight metadata. This does not enable real provider calls.
# Use only in a staging GitHub/deployment environment while CREATIVE_PROVIDER_MODE=disabled.
# CREATIVE_PROVIDER_RUNTIME_ENV=staging
# CREATIVE_STAGING_PROVIDER_PREFLIGHT_ENABLED=true
# CREATIVE_STAGING_IMAGE_PROVIDER=replicate
# CREATIVE_STAGING_PROVIDER_API_TOKEN=
# CREATIVE_STAGING_PROVIDER_CONFIRMATION=staging-only

# Optional Replicate staging adapter shell. This is still image-only and unavailable on the default route path.
# Required with CREATIVE_PROVIDER_MODE=replicate_staging:
# CREATIVE_PROVIDER_RUNTIME_ENV=staging
# CREATIVE_STAGING_IMAGE_PROVIDER=replicate
# CREATIVE_STAGING_PROVIDER_API_TOKEN=
# CREATIVE_STAGING_PROVIDER_CONFIRMATION=staging-only
# Keep false for local, CI, production smoke, and ordinary staging work. Setting true only permits
# construction of the default-disabled HTTP client; it is not external-call approval and does not wire the route.
# CREATIVE_PROVIDER_HTTP_CLIENT_ENABLED=false

# Optional OpenAI GPT Image 2 staging runtime. Keep both switches false outside the dedicated image-staging
# acceptance environment. With every gate enabled, the application route registers the real staging adapter.
# CREATIVE_OPENAI_IMAGE_HTTP_CLIENT_ENABLED=false
# CREATIVE_OPENAI_IMAGE_NETWORK_CALLS_ENABLED=false
# CREATIVE_OPENAI_IMAGE_CONFIRMATION=staging-only
# CREATIVE_OPENAI_IMAGE_API_TOKEN=
# CREATIVE_OPENAI_IMAGE_PROVIDER_ACCOUNT_REF=staging
# CREATIVE_OPENAI_IMAGE_DAILY_BUDGET_USD=0.25
# CREATIVE_OPENAI_IMAGE_DAILY_SPEND_USD=0
# CREATIVE_OPENAI_IMAGE_BUDGET_THRESHOLD_PERCENT=80
# Real acceptance requires the following short-lived approval envelope and exactly two calls.
# CREATIVE_OPENAI_IMAGE_ACCEPTANCE_CONFIRMATION=real-staging-acceptance
# CREATIVE_OPENAI_IMAGE_APPROVAL_DECISION=go-for-image-staging-acceptance
# CREATIVE_OPENAI_IMAGE_APPROVER=
# CREATIVE_OPENAI_IMAGE_APPROVAL_REF=
# CREATIVE_OPENAI_IMAGE_APPROVAL_GRANTED_AT=
# CREATIVE_OPENAI_IMAGE_APPROVAL_EXPIRES_AT=
# CREATIVE_OPENAI_IMAGE_STAGING_ENVIRONMENT=image-staging
# CREATIVE_OPENAI_IMAGE_BRANCH_OR_PR=
# CREATIVE_OPENAI_IMAGE_MAX_CALLS=2
# CREATIVE_OPENAI_IMAGE_PROVIDER_CAP_USD=0.25
# CREATIVE_OPENAI_IMAGE_APP_BUDGET_USD=0.25
# CREATIVE_OPENAI_IMAGE_TOKEN_ROTATION_OWNER=
# CREATIVE_OPENAI_IMAGE_KILL_SWITCH_OWNER=
# CREATIVE_OPENAI_IMAGE_ROLLBACK_OWNER=
# CREATIVE_OPENAI_IMAGE_PRODUCTION_NO_GO=true
# MEDIA_SCAN_PROVIDER=mock

# Optional Google Veo 3.1 Fast staging runtime. The access token must be short-lived and scoped to the
# dedicated staging project. Vertex AI must be enabled and the output prefix must be a private GCS path.
# CREATIVE_GOOGLE_VEO_HTTP_CLIENT_ENABLED=false
# CREATIVE_GOOGLE_VEO_NETWORK_CALLS_ENABLED=false
# CREATIVE_GOOGLE_VEO_CONFIRMATION=staging-only
# CREATIVE_GOOGLE_VEO_ACCESS_TOKEN=
# CREATIVE_GOOGLE_VEO_PROJECT_ID=
# CREATIVE_GOOGLE_VEO_LOCATION=us-central1
# CREATIVE_GOOGLE_VEO_OUTPUT_GCS_URI=gs://private-staging-bucket/veo/
# CREATIVE_GOOGLE_VEO_PROVIDER_ACCOUNT_REF=staging
# CREATIVE_GOOGLE_VEO_DAILY_BUDGET_USD=1.2
# CREATIVE_GOOGLE_VEO_DAILY_SPEND_USD=0
# CREATIVE_GOOGLE_VEO_BUDGET_THRESHOLD_PERCENT=80
# CREATIVE_GOOGLE_VEO_LIFECYCLE_ENABLED=false
# CREATIVE_GOOGLE_VEO_LIFECYCLE_WORKER_ENABLED=false
# CREATIVE_GOOGLE_VEO_POLL_INTERVAL_SECONDS=15
# CREATIVE_GOOGLE_VEO_TIMEOUT_SECONDS=900
# CREATIVE_GOOGLE_VEO_MAX_STATUS_ATTEMPTS=20
# CREATIVE_GOOGLE_VEO_SWEEP_LIMIT=10
# Real acceptance requires a short-lived approval envelope and exactly one paid call.
# CREATIVE_GOOGLE_VEO_ACCEPTANCE_CONFIRMATION=real-staging-acceptance
# CREATIVE_GOOGLE_VEO_APPROVAL_DECISION=go-for-video-staging-acceptance
# CREATIVE_GOOGLE_VEO_APPROVER=
# CREATIVE_GOOGLE_VEO_APPROVAL_REF=
# CREATIVE_GOOGLE_VEO_APPROVAL_GRANTED_AT=
# CREATIVE_GOOGLE_VEO_APPROVAL_EXPIRES_AT=
# CREATIVE_GOOGLE_VEO_STAGING_ENVIRONMENT=video-staging
# CREATIVE_GOOGLE_VEO_BRANCH_OR_PR=
# CREATIVE_GOOGLE_VEO_MAX_CALLS=1
# CREATIVE_GOOGLE_VEO_MAX_GENERATED_SECONDS=8
# CREATIVE_GOOGLE_VEO_PROVIDER_CAP_USD=1.2
# CREATIVE_GOOGLE_VEO_APP_BUDGET_USD=1.2
# CREATIVE_GOOGLE_VEO_TOKEN_ROTATION_OWNER=
# CREATIVE_GOOGLE_VEO_KILL_SWITCH_OWNER=
# CREATIVE_GOOGLE_VEO_ROLLBACK_OWNER=
# CREATIVE_GOOGLE_VEO_PRODUCTION_NO_GO=true

# Guarded ElevenLabs Music v2 staging runtime. Keep disabled outside a dedicated
# staging process and do not set rights confirmations without contract evidence.
# CREATIVE_ELEVENLABS_MUSIC_HTTP_CLIENT_ENABLED=false
# CREATIVE_ELEVENLABS_MUSIC_NETWORK_CALLS_ENABLED=false
# CREATIVE_ELEVENLABS_MUSIC_CONFIRMATION=staging-only
# CREATIVE_ELEVENLABS_MUSIC_API_KEY=
# CREATIVE_ELEVENLABS_MUSIC_PROVIDER_ACCOUNT_REF=staging
# CREATIVE_ELEVENLABS_MUSIC_ENTERPRISE_RIGHTS_CONFIRMED=false
# CREATIVE_ELEVENLABS_MUSIC_TRAINING_OPT_OUT_CONFIRMED=false
# CREATIVE_ELEVENLABS_MUSIC_LICENSE_ID=
# CREATIVE_ELEVENLABS_MUSIC_TERMS_VERSION=
# CREATIVE_ELEVENLABS_MUSIC_DAILY_SPEND_USD=0
# CREATIVE_ELEVENLABS_MUSIC_BUDGET_THRESHOLD_PERCENT=80
# Real acceptance also requires MEDIA_SCAN_PROVIDER=mock and this envelope:
# CREATIVE_ELEVENLABS_MUSIC_ACCEPTANCE_CONFIRMATION=real-staging-acceptance
# CREATIVE_ELEVENLABS_MUSIC_APPROVAL_DECISION=go-for-music-staging-acceptance
# CREATIVE_ELEVENLABS_MUSIC_APPROVER=
# CREATIVE_ELEVENLABS_MUSIC_APPROVAL_REF=
# CREATIVE_ELEVENLABS_MUSIC_APPROVAL_GRANTED_AT=
# CREATIVE_ELEVENLABS_MUSIC_APPROVAL_EXPIRES_AT=
# CREATIVE_ELEVENLABS_MUSIC_STAGING_ENVIRONMENT=music-staging
# CREATIVE_ELEVENLABS_MUSIC_MAX_CALLS=1
# CREATIVE_ELEVENLABS_MUSIC_MAX_GENERATED_SECONDS=30
# CREATIVE_ELEVENLABS_MUSIC_PROVIDER_CAP_USD=0.10
# CREATIVE_ELEVENLABS_MUSIC_APP_BUDGET_USD=0.10
# CREATIVE_ELEVENLABS_MUSIC_PRODUCTION_NO_GO=true
# MEDIA_SCAN_PROVIDER=mock

# Chat messages require an application encryption key before persistence is available.
# Generate 32 random bytes and store the base64 value in the deployment secret store.
# CHAT_MESSAGE_ENCRYPTION_KEY=
# CHAT_MESSAGE_ENCRYPTION_ACTIVE_KEY_ID=v1
# For rotation, replace the single key with comma-separated keyId:base64Key entries.
# CHAT_MESSAGE_ENCRYPTION_KEYS=v1:base64-key,v2:base64-key
# CHAT_RETENTION_WORKER_ENABLED=false
# CHAT_RETENTION_WORKER_INTERVAL_SECONDS=3600
# CHAT_RETENTION_SWEEP_LIMIT=100

# Optional staging-only Provider callback API. This switch is independent from provider dispatch and remains false
# by default. The ingress must send timestamp, signature, and nonce headers; never place this secret in source control.
# CREATIVE_PROVIDER_CALLBACK_ENABLED=false
# CREATIVE_PROVIDER_CALLBACK_SIGNATURE_SECRET=
# CREATIVE_PROVIDER_CALLBACK_REPLAY_WINDOW_SECONDS=300
# CREATIVE_PROVIDER_CALLBACK_MAX_BYTES=262144
# CREATIVE_PROVIDER_CALLBACK_SIDE_EFFECT_LEASE_SECONDS=60

# Optional staging-only Provider polling worker. Both switches remain false by default and require the guarded
# HTTP client above. Enabling these values permits status reads from the dedicated worker only; it is not approval
# for a real Provider call, job creation, paid traffic, or production enablement.
# CREATIVE_PROVIDER_POLLING_ENABLED=false
# CREATIVE_PROVIDER_POLLING_WORKER_ENABLED=false
# CREATIVE_PROVIDER_POLLING_MAX_AGE_SECONDS=3600
# CREATIVE_PROVIDER_POLLING_LEASE_TTL_SECONDS=300
# CREATIVE_PROVIDER_POLLING_INTERVAL_SECONDS=60
# CREATIVE_PROVIDER_POLLING_SWEEP_LIMIT=10
# CREATIVE_PROVIDER_POLLING_REQUIRE_CREDIT_RESERVATION=false

# Optional staging provider budget guard metadata for future adapter wiring.
# The mocked Replicate contract requires estimate and cap metadata before dispatch.
# CREATIVE_STAGING_PROVIDER_ESTIMATE_USD=0.25
# CREATIVE_STAGING_PROVIDER_DAILY_BUDGET_USD=5
# CREATIVE_STAGING_PROVIDER_DAILY_SPEND_USD=0
# CREATIVE_STAGING_PROVIDER_BUDGET_SCOPE=staging:replicate:image
# CREATIVE_STAGING_PROVIDER_BUDGET_THRESHOLD_PERCENT=80
# CREATIVE_STAGING_PROVIDER_ACCOUNT_REF=staging

# Optional creative provider budget external alert configuration.
# Parsed for env/smoke validation only; no outbound provider alert delivery is wired yet.
# CREATIVE_PROVIDER_ALERTS_ENABLED=false
# CREATIVE_PROVIDER_ALERT_CHANNELS=
# CREATIVE_PROVIDER_ALERT_WINDOW_MINUTES=60
# CREATIVE_PROVIDER_ALERT_DELIVERY_FAILED_ALERT_THRESHOLD=2
# CREATIVE_PROVIDER_ALERT_WEBHOOK_URL=
# CREATIVE_PROVIDER_ALERT_WEBHOOK_SECRET=
# CREATIVE_PROVIDER_ALERT_WEBHOOK_TIMEOUT_SECONDS=5
# CREATIVE_PROVIDER_ALERT_SLACK_WEBHOOK_URL=
# CREATIVE_PROVIDER_ALERT_SLACK_TIMEOUT_SECONDS=5
# CREATIVE_PROVIDER_ALERT_EMAIL_WEBHOOK_URL=
# CREATIVE_PROVIDER_ALERT_EMAIL_WEBHOOK_SECRET=
# CREATIVE_PROVIDER_ALERT_EMAIL_TO=
# CREATIVE_PROVIDER_ALERT_EMAIL_FROM=
# CREATIVE_PROVIDER_ALERT_EMAIL_TIMEOUT_SECONDS=5

# Optional media scanner. `manual` leaves completed uploads pending manual review.
# `mock` deterministically classifies local assets by filename/storage key.
# `webhook` marks completed uploads as scanning until POST /api/media/uploads/:id/scan-callback.
# MEDIA_SCAN_PROVIDER=manual
# MEDIA_SCAN_WEBHOOK_SECRET=
# MEDIA_SCAN_REQUEST_ADAPTER=generic-webhook # generic-webhook or clamav-http
# MEDIA_SCAN_REQUEST_URL=
# MEDIA_SCAN_REQUEST_SECRET=
# MEDIA_SCAN_CALLBACK_BASE_URL=
# MEDIA_SCAN_REQUEST_TIMEOUT_SECONDS=10
# MEDIA_SCAN_CALLBACK_SIGNATURE_SECRET=
# MEDIA_SCAN_CALLBACK_SIGNATURE_TOLERANCE_SECONDS=300
# MEDIA_SCAN_RETRY_DELAY_SECONDS=300
# MEDIA_SCAN_TIMEOUT_SECONDS=900
# MEDIA_SCAN_MAX_ATTEMPTS=3
# API_EMBEDDED_WORKERS_ENABLED=false
# WORKER_LEASE_TTL_SECONDS=300
# WORKER_LEASE_RENEW_INTERVAL_SECONDS=60
# SEARCH_INDEX_WORKER_ENABLED=true
# SEARCH_INDEX_WORKER_INTERVAL_SECONDS=5
# SEARCH_INDEX_WORKER_BATCH_SIZE=100
# MEDIA_SCAN_WORKER_ENABLED=false
# MEDIA_SCAN_WORKER_INTERVAL_SECONDS=60
# MEDIA_STORAGE_CLEANUP_WORKER_ENABLED=false
# MEDIA_STORAGE_CLEANUP_WORKER_INTERVAL_SECONDS=300
# MEDIA_STORAGE_CLEANUP_BATCH_SIZE=25
# MEDIA_STORAGE_CLEANUP_RETENTION_DAYS=30
# TASK_STALE_SUBMISSION_WORKER_ENABLED=false
# TASK_STALE_SUBMISSION_WORKER_INTERVAL_SECONDS=300
# TASK_STALE_SUBMISSION_OLDER_THAN_HOURS=72
# TASK_STALE_SUBMISSION_SWEEP_LIMIT=25
# TASK_EXPIRY_WORKER_ENABLED=false
# TASK_EXPIRY_WORKER_INTERVAL_SECONDS=60
# TASK_EXPIRY_SWEEP_LIMIT=50
# MEDIA_SCAN_ALERT_WINDOW_MINUTES=60
# MEDIA_SCAN_CALLBACK_DENIED_ALERT_THRESHOLD=3
# MEDIA_SCAN_DISPATCH_FAILED_ALERT_THRESHOLD=3
# MEDIA_SCAN_TIMEOUT_ALERT_THRESHOLD=2
# MEDIA_SCAN_ALERT_DELIVERY_FAILED_ALERT_THRESHOLD=2
# MEDIA_SCAN_ALERT_WEBHOOK_URL=
# MEDIA_SCAN_ALERT_WEBHOOK_SECRET=
# MEDIA_SCAN_ALERT_WEBHOOK_TIMEOUT_SECONDS=5
# MEDIA_SCAN_ALERT_SLACK_WEBHOOK_URL=
# MEDIA_SCAN_ALERT_SLACK_TIMEOUT_SECONDS=5
# MEDIA_SCAN_ALERT_EMAIL_WEBHOOK_URL=
# MEDIA_SCAN_ALERT_EMAIL_WEBHOOK_SECRET=
# MEDIA_SCAN_ALERT_EMAIL_TO=
# MEDIA_SCAN_ALERT_EMAIL_FROM=
# MEDIA_SCAN_ALERT_EMAIL_TIMEOUT_SECONDS=5

# Audit retention is disabled and held by default. Enable only with durable S3 archive storage and an approved policy window.
# AUDIT_RETENTION_DAYS=730
# AUDIT_RETENTION_BATCH_SIZE=100
# AUDIT_RETENTION_MIN_RETAINED=1000
# AUDIT_RETENTION_LEGAL_HOLD=true
# AUDIT_RETENTION_PRUNE_ENABLED=false

# OAuth secrets stay in the deployment environment. Client ids, exact redirect URIs,
# scopes, allowlisted SecretRefs, and enabled state can be managed in the Admin UI.
# Use secret://env/OAUTH_GOOGLE_CLIENT_SECRET and secret://env/OAUTH_GITHUB_CLIENT_SECRET in Admin;
# never paste either secret into an Admin field.
# When omitted locally, provider buttons use dev OAuth callback mode.
# OAUTH_DEV_MODE=disabled
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GOOGLE_REDIRECT_URI=http://127.0.0.1:8787/api/auth/oauth/google/callback
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=
# OAUTH_GITHUB_REDIRECT_URI=http://127.0.0.1:8787/api/auth/oauth/github/callback
# OAUTH_DISCORD_CLIENT_ID=
# OAUTH_DISCORD_CLIENT_SECRET=
# OAUTH_DISCORD_REDIRECT_URI=http://127.0.0.1:8787/api/auth/oauth/discord/callback
# OAUTH_APPLE_CLIENT_ID=
# OAUTH_APPLE_TEAM_ID=
# OAUTH_APPLE_KEY_ID=
# OAUTH_APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# OAUTH_APPLE_REDIRECT_URI=http://127.0.0.1:8787/api/auth/oauth/apple/callback

# Node 24.14+ can initialize provider proxy routing from an env file at runtime.
# Keep local API addresses in NO_PROXY so callbacks and health checks stay direct.
# NODE_USE_ENV_PROXY=1
# HTTPS_PROXY=http://proxy.example.com:8080
# HTTP_PROXY=http://proxy.example.com:8080
# NO_PROXY=127.0.0.1,localhost

# OpenAI Chat is staging-only and fails closed unless every gate is explicit.
# The live smoke requires CHAT_OPENAI_LIVE_SMOKE_CONFIRMATION=real-staging-call.
# Full application acceptance uses real-staging-acceptance and exactly five Provider calls.
# Never enable these values in the production product runtime or commit the token.
# CHAT_PROVIDER_MODE=disabled
# CHAT_OPENAI_HTTP_CLIENT_ENABLED=false
# CHAT_OPENAI_NETWORK_CALLS_ENABLED=false
# CHAT_OPENAI_SAFETY_CLASSIFIER_ENABLED=false
# CHAT_OPENAI_CONFIRMATION=
# CHAT_OPENAI_API_TOKEN=
# CHAT_OPENAI_LIVE_SMOKE_CONFIRMATION=
# CHAT_OPENAI_APPROVAL_DECISION=
# CHAT_OPENAI_APPROVER=
# CHAT_OPENAI_APPROVAL_REF=
# CHAT_OPENAI_APPROVAL_EXPIRES_AT=
# CHAT_OPENAI_STAGING_ENVIRONMENT=
# CHAT_OPENAI_LIVE_SMOKE_MAX_CALLS=
# CHAT_OPENAI_PROVIDER_CAP_USD=
# CHAT_OPENAI_LIVE_SMOKE_APP_BUDGET_USD=
# CHAT_OPENAI_TOKEN_ROTATION_OWNER=
# CHAT_OPENAI_KILL_SWITCH_OWNER=
# CHAT_OPENAI_ROLLBACK_OWNER=
# CHAT_OPENAI_LIVE_SMOKE_PRODUCTION_NO_GO=true
# CHAT_ATTACHMENT_BYTES_ENABLED=false

# API key CIDR allowlists use the direct socket address by default. Enable only when the
# API is behind a trusted proxy that overwrites X-Forwarded-For from untrusted clients.
# API_KEY_TRUST_PROXY=false
