    "GET /api/developer/service-accounts",
    "POST /api/developer/service-accounts",
    "POST /api/developer/service-accounts/:id/transitions",
    "POST /api/developer/service-accounts/:id/keys",
    "POST /api/developer/service-accounts/:id/keys/:keyId/rotate",
    "POST /api/developer/service-accounts/:id/keys/:keyId/revoke",
    "GET /api/developer/principal"
