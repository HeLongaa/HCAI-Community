    "GET /api/admin/developer/service-accounts",
    "GET /api/admin/developer/service-accounts/export",
    "GET /api/admin/developer/metrics",
    "POST /api/admin/developer/service-accounts/:id/revoke",
    "POST /api/admin/developer/service-accounts/:id/keys/:keyId/revoke"
  ],
  "forbiddenProjectionFields": ["secretHash", "plaintextKey_after_issue", "rawClientIp"],
  "bulkDisposition": "not_applicable_high_risk_immediate_single_target_revoke"
}
