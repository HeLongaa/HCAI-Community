{
  "schemaVersion": 1,
  "taskId": "DEV-01",
  "scope": "personal_accounts_only",
  "defaultEnabled": false,
  "models": ["DeveloperAccessControl", "ServiceAccount", "ApiKeyCredential"],
  "migration": "0085_developer_access_credentials",
  "key": {
    "prefix": "mfk",
    "plaintextReturnedOnce": true,
    "persistedSecret": "sha256_hash_only",
