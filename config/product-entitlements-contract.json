{
  "schemaVersion": 1,
  "taskId": "ENT-01",
  "scope": "personal_accounts_only",
  "models": ["EntitlementPlan", "EntitlementPlanVersion", "PersonalEntitlementGrant", "EntitlementGrantEvent"],
  "planStatuses": ["draft", "active", "retired"],
  "grantStatuses": ["scheduled", "active", "revoked", "expired"],
  "immutableModels": ["EntitlementPlanVersion", "EntitlementGrantEvent"],
  "permissions": ["entitlements:read", "admin:entitlements:read", "admin:entitlements:manage", "admin:entitlements:transition"],
  "routes": [
    { "method": "GET", "path": "/api/entitlements/me", "permission": "entitlements:read" },
    { "method": "POST", "path": "/api/entitlements/evaluate", "permission": "entitlements:read" },
    { "method": "GET", "path": "/api/admin/entitlements/plans", "permission": "admin:entitlements:read" },
    { "method": "GET", "path": "/api/admin/entitlements/plans/export", "permission": "admin:entitlements:read" },
    { "method": "GET", "path": "/api/admin/entitlements/plans/:id", "permission": "admin:entitlements:read" },
    { "method": "POST", "path": "/api/admin/entitlements/plans", "permission": "admin:entitlements:manage" },
    { "method": "POST", "path": "/api/admin/entitlements/plans/:id/versions", "permission": "admin:entitlements:manage" },
    { "method": "POST", "path": "/api/admin/entitlements/plans/:id/transitions", "permission": "admin:entitlements:transition" },
    { "method": "GET", "path": "/api/admin/entitlements/grants", "permission": "admin:entitlements:read" },
    { "method": "GET", "path": "/api/admin/entitlements/grants/:id", "permission": "admin:entitlements:read" },
    { "method": "POST", "path": "/api/admin/entitlements/grants", "permission": "admin:entitlements:manage" },
    { "method": "POST", "path": "/api/admin/entitlements/grants/:id/transitions", "permission": "admin:entitlements:transition" },
    { "method": "POST", "path": "/api/admin/entitlements/grants/expiry-sweep", "permission": "admin:entitlements:transition" },
    { "method": "POST", "path": "/api/admin/entitlements/evaluate", "permission": "admin:entitlements:read" }
  ],
  "creativeCapabilityPattern": "creative.<workspace>.<mode>",
  "creativeQuotaPattern": "creative.daily.<workspace>",
  "fallbackSource": "role_fallback",
  "grantSource": "personal_grant",
  "maximumListLimit": 100,
  "maximumCapabilityEntries": 100,
  "maximumQuotaEntries": 100,
  "maximumQuotaValue": 1000000,
  "singleGrantConstraints": ["active", "scheduled"],
  "economicBoundary": {
    "personalAccountOnly": true,
    "paymentRequired": false,
    "withdrawable": false,
    "convertibleToProviderCurrency": false
  },
  "exportKind": "personal-entitlements.snapshot",
  "realProviderCalls": false,
  "tenantModels": false
}
