  "forbiddenCapabilities": {
    "append_only": ["create", "update", "delete", "bulkMutate"],
    "immutable_evidence": ["create", "update", "delete", "bulkMutate"],
    "state_transition": ["arbitraryUpdate", "hardDelete"]
  }
