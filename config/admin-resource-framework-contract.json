    { "id": "domainEventInbox", "model": "DomainEventConsumerInbox", "routeGroup": "admin", "listRoute": "GET /api/admin/domain-event-inbox", "detailRoute": "GET /api/admin/domain-event-inbox/:id", "recoveryRoutes": ["POST /api/admin/domain-event-inbox/:id/retry", "POST /api/admin/domain-event-inbox/:id/compensate"] },
    { "id": "jobRuns", "model": "JobRun", "routeGroup": "admin", "listRoute": "GET /api/admin/jobs/runs", "detailRoute": "GET /api/admin/jobs/runs/:id", "recoveryRoutes": ["POST /api/admin/jobs/runs/:id/cancel", "POST /api/admin/jobs/runs/:id/retry", "POST /api/admin/jobs/runs/:id/rerun"] },
