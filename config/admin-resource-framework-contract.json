    { "id": "pointsLedger", "model": "PointLedger", "routeGroup": "admin", "listRoute": "GET /api/admin/points/ledger", "exportRoute": "GET /api/admin/points/ledger.csv" },
    { "id": "mediaReviewQueue", "model": "MediaAsset", "routeGroup": "admin", "listRoute": "GET /api/media/review-queue", "recoveryRoutes": ["POST /api/media/uploads/:id/scan", "POST /api/media/uploads/:id/scan-retry"] },
    { "id": "mediaAssets", "model": "MediaAsset", "routeGroup": "admin", "listRoute": "GET /api/admin/media/assets", "detailRoute": "GET /api/admin/media/assets/:id", "exportRoute": "GET /api/admin/media/assets/export", "recoveryRoutes": ["POST /api/admin/media/assets/:id/:action", "POST /api/admin/media/assets/:id/scan", "POST /api/admin/media/assets/:id/scan-retry", "POST /api/admin/media/assets/bulk-actions"] },
