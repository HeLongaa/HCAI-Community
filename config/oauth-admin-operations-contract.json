{
  "schemaVersion": 1,
  "task": "AUTH-01",
  "providers": ["google", "github", "apple", "discord"],
  "permissions": {
    "read": "admin:auth:read",
    "manage": "admin:auth:manage"
  },
  "routes": [
    { "method": "GET", "path": "/api/admin/auth/oauth/providers", "permission": "admin:auth:read" },
    { "method": "POST", "path": "/api/admin/auth/oauth/providers/:provider/status", "permission": "admin:auth:manage" },
    { "method": "PUT", "path": "/api/admin/auth/oauth/providers/:provider/configuration", "permission": "admin:auth:manage" },
    { "method": "GET", "path": "/api/admin/auth/oauth/accounts", "permission": "admin:auth:read" },
    { "method": "DELETE", "path": "/api/admin/auth/oauth/accounts/:id", "permission": "admin:auth:manage" },
    { "method": "GET", "path": "/api/admin/auth/oauth/authorization-requests", "permission": "admin:auth:read" },
    { "method": "POST", "path": "/api/admin/auth/oauth/authorization-requests/:id/revoke", "permission": "admin:auth:manage" }
  ],
  "secretBoundary": {
    "rawSecretsEnvironmentOnly": true,
    "adminConfigFields": ["clientId", "redirectUri", "scopes", "clientSecretRef"],
    "forbiddenApiFields": ["clientSecret", "privateKey", "stateHash", "redirectTo", "linkUserId", "token", "secret"]
  },
  "providerControl": {
    "missingRowEnabled": true,
    "optimisticVersioning": true,
    "disableBlocksPublicMetadataAndStart": true,
    "enableRequiresEnvironmentAvailability": true
  },
  "providerConfiguration": {
    "optimisticVersioning": true,
    "inFlightAuthorizationPinsVersion": true,
    "secretReferenceScheme": "secret://",
    "fixedProviderEndpoints": true
  },
  "accountUnlink": {
    "preserveFinalSignInMethod": true,
    "auditInSameTransaction": true
  },
  "authorizationRequest": {
    "pendingOnlyRevocation": true,
    "safeProjectionOnly": true,
    "expiredRetentionDays": 30
  }
}
