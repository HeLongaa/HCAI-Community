{
  "schemaVersion": 1,
  "scope": "personal_accounts_only",
  "taskId": "ARC-03",
  "policyDocument": "docs/LIST_QUERY_CONTRACT.md",
  "defaults": {
    "pagination": "cursor",
    "maxLimit": 100,
    "cursorField": "id",
    "exportFormats": ["json", "csv"]
  },
  "resources": [
    { "id": "tasks", "routes": ["GET /api/tasks"], "cursor": true, "filters": ["status", "category", "q"], "sorts": ["createdAt", "reward"], "export": false },
    { "id": "taskProposals", "routes": ["GET /api/tasks/:id/proposals"], "cursor": true, "filters": ["status"], "sorts": ["createdAt"], "export": false },
    { "id": "taskSubmissions", "routes": ["GET /api/tasks/:id/submissions"], "cursor": true, "filters": ["status"], "sorts": ["createdAt"], "export": false },
    { "id": "posts", "routes": ["GET /api/posts"], "cursor": true, "filters": ["category", "tag"], "sorts": ["new", "hot", "unanswered", "solved"], "export": false },
    { "id": "ownerPosts", "routes": ["GET /api/posts/mine"], "cursor": true, "filters": ["status"], "sorts": ["updatedAt"], "export": false },
    { "id": "adminCommunityPosts", "routes": ["GET /api/admin/community/posts", "GET /api/admin/community/metrics"], "cursor": true, "filters": ["search", "status", "deletionState", "moderationState", "category", "authorHandle", "dateFrom", "dateTo"], "sorts": ["createdAt", "updatedAt", "status", "likesCount", "viewsCount"], "export": true, "exportRoutes": ["GET /api/admin/community/metrics/export"] },
    { "id": "adminCommunityComments", "routes": ["GET /api/admin/community/comments"], "cursor": true, "filters": ["search", "postId", "deletionState", "moderationState", "authorHandle", "dateFrom", "dateTo"], "sorts": ["createdAt", "updatedAt"], "export": true, "exportRoutes": ["GET /api/admin/community/metrics/export"] },
    { "id": "profiles", "routes": ["GET /api/profiles"], "cursor": true, "filters": ["lane", "q"], "sorts": ["rank"], "export": false },
    { "id": "adminUsers", "routes": ["GET /api/admin/users", "GET /api/admin/users/metrics"], "cursor": true, "filters": ["status", "role", "tag", "search", "dateFrom", "dateTo"], "sorts": ["createdAt", "updatedAt", "displayName"], "export": true, "exportRoutes": ["GET /api/admin/users/metrics/export"] },
    { "id": "adminAuthFailures", "routes": ["GET /api/admin/auth/failures", "GET /api/admin/auth/metrics"], "cursor": true, "filters": ["method", "reasonCode", "identityHash", "dateFrom", "dateTo"], "sorts": ["occurredAt"], "export": false },
    { "id": "library", "routes": ["GET /api/library"], "cursor": true, "filters": ["type", "q"], "sorts": ["createdAt"], "export": false },
    { "id": "mediaAssets", "routes": ["GET /api/media/assets"], "cursor": true, "filters": ["purpose", "status", "q"], "sorts": ["createdAt"], "export": false },
    { "id": "mediaReviewQueue", "routes": ["GET /api/media/review-queue"], "cursor": true, "filters": ["status", "purpose", "q"], "sorts": ["createdAt"], "export": false },
    { "id": "adminMediaAssets", "routes": ["GET /api/admin/media/assets"], "cursor": true, "filters": ["lifecycle", "ownerHandle", "status", "purpose", "mediaType", "q"], "sorts": ["createdAt", "updatedAt", "fileName"], "export": true, "exportRoutes": ["GET /api/admin/media/assets/export"] },
    { "id": "mediaScanJobs", "routes": ["GET /api/media/scan-jobs"], "cursor": true, "filters": ["status", "provider"], "sorts": ["updatedAt"], "export": true, "exportRoutes": ["GET /api/media/scan-jobs/archive"] },
    { "id": "notifications", "routes": ["GET /api/notifications"], "cursor": true, "filters": ["readState", "type", "resourceType"], "sorts": ["createdAt"], "export": false },
    { "id": "pointsLedger", "routes": ["GET /api/points/ledger"], "cursor": true, "filters": ["userHandle", "status", "q"], "sorts": ["createdAt"], "export": false },
    { "id": "adminPointsLedger", "routes": ["GET /api/admin/points/ledger"], "cursor": true, "filters": ["userHandle", "status", "q"], "sorts": ["createdAt"], "export": true, "exportRoutes": ["GET /api/admin/points/ledger.csv"] },
    { "id": "personalBillingLedger", "routes": ["GET /api/billing/ledger"], "cursor": true, "filters": ["unit", "status", "sourceType", "search", "dateFrom", "dateTo"], "sorts": ["asc", "desc"], "export": true, "exportRoutes": ["GET /api/billing/ledger/export"] },
    { "id": "adminPersonalBillingLedger", "routes": ["GET /api/admin/billing/users/:handle/ledger"], "cursor": true, "filters": ["unit", "status", "sourceType", "search", "dateFrom", "dateTo"], "sorts": ["asc", "desc"], "export": true, "exportRoutes": ["GET /api/admin/billing/users/:handle/ledger/export"] },
    { "id": "adminReviews", "routes": ["GET /api/admin/reviews"], "cursor": true, "filters": ["queue", "status"], "sorts": ["createdAt"], "export": false },
    { "id": "adminAudit", "routes": ["GET /api/admin/audit"], "cursor": true, "filters": ["action", "resourceType", "actorId"], "sorts": ["createdAt"], "export": true, "exportRoutes": ["GET /api/admin/audit/export"] },
    { "id": "adminAccountingReconciliation", "routes": ["GET /api/admin/accounting/reconciliation"], "cursor": true, "filters": ["status", "unit", "q"], "sorts": ["createdAt"], "export": true, "exportRoutes": ["GET /api/admin/accounting/reconciliation/export"] },
    { "id": "adminCreativeGenerations", "routes": ["GET /api/admin/creative/generations", "GET /api/admin/creative/generations/summary", "GET /api/admin/creative/generations/business-metrics"], "cursor": true, "filters": ["userHandle", "workspace", "mode", "status", "providerId", "reviewRequired", "mediaAssetId", "dateFrom", "dateTo"], "sorts": ["createdAt", "updatedAt", "status"], "export": true, "exportRoutes": ["GET /api/admin/creative/generations/export", "GET /api/admin/creative/generations/business-metrics/export"] },
    { "id": "personalGenerationCenter", "routes": ["GET /api/creative/generation-center", "GET /api/creative/generation-center/summary"], "cursor": true, "filters": ["workspace", "status", "dateFrom", "dateTo"], "sorts": ["createdAt", "updatedAt", "status"], "export": true, "exportRoutes": ["GET /api/creative/generation-center/export"] },
    { "id": "adminCreativeGenerationExecutions", "routes": ["GET /api/admin/creative/executions"], "cursor": true, "filters": ["workspace", "status"], "sorts": ["createdAt"], "export": false },
    { "id": "adminSecurityEvents", "routes": ["GET /api/admin/security/events"], "cursor": true, "filters": ["source", "severity", "type"], "sorts": ["occurredAt"], "export": false },
    { "id": "adminSecurityAlerts", "routes": ["GET /api/admin/security/alerts"], "cursor": true, "filters": ["status", "severity", "source"], "sorts": ["createdAt"], "export": true, "exportRoutes": ["GET /api/admin/security/alerts/:id/export"] },
    { "id": "adminGlobalSearch", "routes": ["GET /api/admin/search"], "cursor": true, "filters": ["q", "types"], "sorts": ["relevance", "timestamp"], "export": false },
    { "id": "domainEvents", "routes": ["GET /api/admin/domain-events"], "cursor": true, "filters": ["type", "aggregateType", "aggregateId", "status"], "sorts": ["occurredAt"], "export": false },
    { "id": "domainEventInbox", "routes": ["GET /api/admin/domain-event-inbox"], "cursor": true, "filters": ["consumerKey", "status", "aggregateType", "aggregateId"], "sorts": ["receivedAt"], "export": false },
    { "id": "jobRuns", "routes": ["GET /api/admin/jobs/runs"], "cursor": true, "filters": ["definitionKey", "status"], "sorts": ["createdAt"], "export": false },
    { "id": "supportRequests", "routes": ["GET /api/support/requests"], "cursor": true, "filters": ["status", "category"], "sorts": ["createdAt"], "export": false },
    { "id": "releaseChanges", "routes": ["GET /api/admin/releases"], "cursor": true, "filters": ["status", "targetEnvironment", "changeType"], "sorts": ["createdAt"], "export": false },
    { "id": "modelRouteDecisions", "routes": ["GET /api/admin/model-control/route-decisions"], "cursor": true, "filters": ["source", "status", "modality", "environment", "policyId"], "sorts": ["createdAt", "status", "reasonCode", "source"], "export": true, "exportRoutes": ["GET /api/admin/model-control/governance-export"] },
    { "id": "providerSecretRefs", "routes": ["GET /api/admin/model-control/secret-refs"], "cursor": true, "filters": ["providerId", "environment", "purpose", "search"], "sorts": ["createdAt", "expiresAt", "purpose", "externalVersion"], "export": true, "exportRoutes": ["GET /api/admin/model-control/governance-export"] },
    { "id": "modelPromotions", "routes": ["GET /api/admin/model-control/promotions"], "cursor": true, "filters": ["status", "modelDeploymentId"], "sorts": ["createdAt"], "export": true, "exportRoutes": ["GET /api/admin/model-control/governance-export"] },
    { "id": "providerOperationalPolicies", "routes": ["GET /api/admin/model-control/provider-operations"], "cursor": true, "filters": ["providerId", "environment", "workspace", "status", "search"], "sorts": ["updatedAt", "scopeKey", "status", "workspace"], "export": true, "exportRoutes": ["GET /api/admin/model-control/provider-operations-export"] },
    { "id": "providerHealthEvidence", "routes": ["GET /api/admin/model-control/provider-operations/:id/health"], "cursor": true, "filters": ["status"], "sorts": ["checkedAt"], "export": true, "exportRoutes": ["GET /api/admin/model-control/provider-operations-export"] },
    { "id": "aiEvaluationSuites", "routes": ["GET /api/admin/model-control/evaluation-suites"], "cursor": true, "filters": ["modality", "operation", "search"], "sorts": ["createdAt"], "export": true, "exportRoutes": ["GET /api/admin/model-control/evaluation-export"] },
    { "id": "aiEvaluationPolicies", "routes": ["GET /api/admin/model-control/evaluation-policies"], "cursor": true, "filters": ["suiteId", "environment", "modality"], "sorts": ["createdAt"], "export": true, "exportRoutes": ["GET /api/admin/model-control/evaluation-export"] },
    { "id": "aiEvaluationRuns", "routes": ["GET /api/admin/model-control/evaluation-runs"], "cursor": true, "filters": ["suiteId", "policyId", "modelVersionId", "modelDeploymentId", "status"], "sorts": ["createdAt"], "export": true, "exportRoutes": ["GET /api/admin/model-control/evaluation-export"] },
    { "id": "providerLegalReviews", "routes": ["GET /api/admin/model-control/provider-legal-reviews"], "cursor": true, "filters": ["providerId", "modelVersionId", "environment", "decision"], "sorts": ["createdAt"], "export": true, "exportRoutes": ["GET /api/admin/model-control/provider-legal-export"] },
    { "id": "notificationTemplates", "routes": ["GET /api/admin/notifications/templates", "GET /api/admin/notifications/templates/metrics"], "cursor": true, "filters": ["status", "category", "search", "includeDeleted"], "sorts": ["key", "createdAt", "updatedAt"], "export": true, "exportRoutes": ["GET /api/admin/notifications/templates/export"] },
    { "id": "notificationDeliveries", "routes": ["GET /api/admin/notifications/deliveries", "GET /api/admin/notifications/deliveries/metrics", "GET /api/admin/notifications/channels"], "cursor": true, "filters": ["status", "channel", "notificationType", "search", "dateFrom", "dateTo"], "sorts": ["createdAt", "availableAt", "updatedAt"], "export": true, "exportRoutes": ["GET /api/admin/notifications/deliveries/export", "GET /api/admin/notifications/deliveries/metrics/export"] },
    { "id": "moderationCases", "routes": ["GET /api/trust/cases", "GET /api/admin/trust/cases", "GET /api/admin/trust/cases/metrics"], "cursor": true, "filters": ["status", "priority", "targetType", "category", "search"], "sorts": ["createdAt", "priority"], "export": true, "exportRoutes": ["GET /api/admin/trust/cases/export"] },
    { "id": "safetySignals", "routes": ["GET /api/admin/trust/signals"], "cursor": true, "filters": ["caseId", "signalType"], "sorts": ["createdAt"], "export": false },
    { "id": "moderationQueue", "routes": ["GET /api/admin/trust/queue", "GET /api/admin/trust/operations/metrics"], "cursor": true, "filters": ["status", "priority", "assignment", "sla", "search"], "sorts": ["createdAt", "dueAt"], "export": false },
    { "id": "personalServiceAccounts", "routes": ["GET /api/developer/service-accounts"], "cursor": true, "filters": ["status", "search"], "sorts": ["createdAt", "updatedAt", "name"], "export": false },
    { "id": "adminServiceAccounts", "routes": ["GET /api/admin/developer/service-accounts", "GET /api/admin/developer/metrics"], "cursor": true, "filters": ["status", "search", "ownerHandle"], "sorts": ["createdAt", "updatedAt", "name"], "export": true, "exportRoutes": ["GET /api/admin/developer/service-accounts/export"] },
    { "id": "personalWebhookSubscriptions", "routes": ["GET /api/developer/webhooks"], "cursor": true, "filters": ["status", "eventType", "search"], "sorts": ["createdAt", "updatedAt", "name"], "export": false },
    { "id": "personalWebhookDeliveries", "routes": ["GET /api/developer/webhook-deliveries"], "cursor": true, "filters": ["status", "eventType", "subscriptionId", "search"], "sorts": ["createdAt", "availableAt"], "export": false },
    { "id": "adminWebhookSubscriptions", "routes": ["GET /api/admin/developer/webhooks", "GET /api/admin/developer/webhooks/metrics"], "cursor": true, "filters": ["status", "eventType", "search", "ownerHandle"], "sorts": ["createdAt", "updatedAt", "name"], "export": false },
    { "id": "adminWebhookDeliveries", "routes": ["GET /api/admin/developer/webhook-deliveries"], "cursor": true, "filters": ["status", "eventType", "subscriptionId", "search", "ownerHandle"], "sorts": ["createdAt", "availableAt"], "export": false }
  ]
}
