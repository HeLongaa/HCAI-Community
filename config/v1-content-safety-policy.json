  "riskCategories": [
    {
      "id": "child_sexual_exploitation",
      "severity": "critical",
      "appliesTo": ["image", "chat", "video", "music"],
      "definition": "Sexual content, grooming, exploitation, or sexualized depiction involving a person known or reasonably suspected to be under 18.",
      "reasonCode": "SAFETY_CHILD_SEXUAL",
      "escalation": "preserve_minimal_evidence_and_follow_legal_reporting_runbook"
    },
    {
      "id": "non_consensual_intimate_content",
      "severity": "critical",
      "appliesTo": ["image", "chat", "video", "music"],
      "definition": "Creation, alteration, description, or distribution of intimate content without the depicted person's consent.",
      "reasonCode": "SAFETY_NON_CONSENSUAL_INTIMATE",
      "escalation": "trust_and_safety_priority"
    },
    {
      "id": "hate_extremist_praise_or_recruitment",
      "severity": "critical",
      "appliesTo": ["image", "chat", "video", "music"],
      "definition": "Praise, recruitment, operational support, or targeted dehumanization for hateful or extremist activity.",
      "reasonCode": "SAFETY_HATE_EXTREMISM",
      "escalation": "trust_and_safety_priority"
    },
    {
      "id": "violent_wrongdoing_instructions",
      "severity": "critical",
      "appliesTo": ["image", "chat", "video", "music"],
      "definition": "Actionable instructions, optimization, or encouragement for violent wrongdoing or serious physical harm.",
      "reasonCode": "SAFETY_VIOLENT_WRONGDOING",
      "escalation": "trust_and_safety_priority"
    },
    {
      "id": "credential_theft_malware_or_cyber_abuse",
      "severity": "critical",
      "appliesTo": ["image", "chat"],
      "definition": "Credential harvesting, phishing interfaces, malware, unauthorized access, evasion, or destructive cyber abuse.",
      "reasonCode": "SAFETY_CYBER_ABUSE",
      "escalation": "security_and_trust_safety"
    },
    {
      "id": "self_harm_instructions_or_encouragement",
      "severity": "critical",
      "appliesTo": ["image", "chat", "video", "music"],
      "definition": "Instructions, encouragement, romanticization, or personalized optimization of suicide or self-harm; supportive prevention content is excluded.",
      "reasonCode": "SAFETY_SELF_HARM",
      "escalation": "crisis_safe_response_path"
    },
    {
      "id": "adult_explicit_sexual_content",
      "severity": "high",
      "appliesTo": ["image", "chat", "video", "music"],
      "definition": "Pornographic or explicit sexual generation involving adults, excluding neutral health, safety, or educational context.",
      "reasonCode": "SAFETY_EXPLICIT_SEXUAL",
      "escalation": "standard"
    },
    {
      "id": "graphic_violence_or_gore",
      "severity": "high",
      "appliesTo": ["image", "chat", "video", "music"],
      "definition": "Graphic gore, torture, dismemberment, or realistic severe injury outside a legitimate contextual exception.",
      "reasonCode": "SAFETY_GRAPHIC_VIOLENCE",
      "escalation": "standard"
    },
    {
      "id": "targeted_harassment_threats_or_doxxing",
      "severity": "high",
      "appliesTo": ["image", "chat", "video", "music"],
      "definition": "Targeted abuse, credible threats, humiliation, stalking assistance, or exposure of private identifying information.",
      "reasonCode": "SAFETY_TARGETED_ABUSE",
      "escalation": "trust_and_safety"
    },
    {
      "id": "fraud_impersonation_or_deceptive_media",
      "severity": "high",
      "appliesTo": ["image", "chat", "video", "music"],
      "definition": "Fraud, scams, deceptive impersonation, fabricated evidence, or media intended to mislead people about authenticity.",
      "reasonCode": "SAFETY_FRAUD_DECEPTION",
      "escalation": "trust_and_safety"
    },
    {
      "id": "election_or_political_persuasion",
      "severity": "high",
      "appliesTo": ["image", "chat", "video", "music"],
      "definition": "Targeted political persuasion, election interference, false voting information, or deceptive synthetic campaign media.",
      "reasonCode": "SAFETY_POLITICAL_PERSUASION",
      "escalation": "policy_and_legal"
    },
    {
      "id": "real_person_likeness_voice_or_biometrics",
      "severity": "high",
      "appliesTo": ["image", "chat", "video", "music"],
      "definition": "Use of a real person's face, voice, identity, or biometric traits where consent, authority, purpose, or disclosure is uncertain.",
      "reasonCode": "SAFETY_REAL_PERSON_IDENTITY",
      "escalation": "rights_and_safety_review"
    },
    {
      "id": "public_figure_sensitive_context",
      "severity": "high",
      "appliesTo": ["image", "chat", "video", "music"],
      "definition": "A public figure in sexual, violent, medical, criminal, endorsement, election, or other materially misleading context.",
      "reasonCode": "SAFETY_PUBLIC_FIGURE",
      "escalation": "rights_and_safety_review"
    },
    {
      "id": "personal_data_or_sensitive_attribute_inference",
      "severity": "high",
      "appliesTo": ["image", "chat", "video", "music"],
      "definition": "Exposure of personal data or inference of sensitive traits, identity, health, finances, location, or protected attributes.",
      "reasonCode": "SAFETY_PRIVACY_INFERENCE",
      "escalation": "privacy_review"
    },
    {
      "id": "regulated_advice_or_high_impact_decision",
      "severity": "high",
      "appliesTo": ["chat"],
      "definition": "Personalized legal, medical, financial, employment, housing, education, insurance, or other high-impact advice or decisions.",
      "reasonCode": "SAFETY_REGULATED_ADVICE",
      "escalation": "qualified_domain_review"
    },
    {
      "id": "weapons_drugs_or_regulated_goods",
      "severity": "high",
      "appliesTo": ["image", "chat", "video", "music"],
      "definition": "Operational weapons use, illicit drug production, evasion, or promotion and sale of regulated goods.",
      "reasonCode": "SAFETY_REGULATED_GOODS",
      "escalation": "policy_review"
    },
    {
      "id": "copyright_trademark_artist_style_or_lyrics",
      "severity": "high",
      "appliesTo": ["image", "chat", "video", "music"],
      "definition": "Potentially unauthorized copyrighted material, trademarks, living-artist style imitation, lyrics, samples, characters, or model-license conflicts.",
      "reasonCode": "RIGHTS_IP_OR_LICENSE",
      "escalation": "rights_review"
    },
    {
      "id": "minor_nonsexual_sensitive_depiction",
      "severity": "high",
      "appliesTo": ["image", "chat", "video", "music"],
      "definition": "Nonsexual depiction of a minor in exploitative, dangerous, identity-sensitive, commercial, or otherwise high-risk context.",
      "reasonCode": "SAFETY_MINOR_SENSITIVE",
      "escalation": "child_safety_review"
    },
    {
      "id": "medical_legal_newsworthy_or_educational_sensitive_context",
      "severity": "medium",
      "appliesTo": ["image", "chat", "video", "music"],
      "definition": "Sensitive material with a plausible medical, legal, journalistic, documentary, historical, educational, or safety purpose requiring context review.",
      "reasonCode": "SAFETY_CONTEXT_REQUIRED",
      "escalation": "standard_review"
    },
    {
      "id": "benign_original_or_authorized_creation",
      "severity": "low",
      "appliesTo": ["image", "chat", "video", "music"],
      "definition": "Benign original creation, authorized transformation, neutral assistance, or clearly safe educational and fictional content.",
      "reasonCode": "SAFETY_ALLOWED_BASELINE",
      "escalation": "none"
    }
  ],
