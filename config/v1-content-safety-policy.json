  "responsibilityStages": [
    {
      "id": "pre_dispatch",
      "order": 1,
      "owner": "application",
      "mustCompleteBefore": "provider_request_or_provider_cost",
      "requiredInputs": ["prompt hash", "safe redacted preview", "modality", "mode", "input asset ids", "rights attestation", "region"],
      "allowedOutcomes": ["prohibited", "block", "review", "allow"],
      "failureDisposition": "block"
    },
    {
      "id": "provider_native",
      "order": 2,
      "owner": "provider_and_adapter",
      "mustCompleteBefore": "provider_output_acceptance",
      "requiredInputs": ["provider policy version when available", "safe request correlation", "provider safety options"],
      "allowedOutcomes": ["provider_refused", "provider_flagged", "provider_allowed", "provider_unknown"],
      "failureDisposition": "block"
    },
    {
      "id": "post_output",
      "order": 3,
      "owner": "application",
      "mustCompleteBefore": "preview_playback_download_or_sharing",
      "requiredInputs": ["output asset ids", "provider safety result", "media scan result", "provenance metadata"],
      "allowedOutcomes": ["reject", "quarantine", "review", "release_candidate"],
      "failureDisposition": "quarantine"
    },
    {
      "id": "human_review",
      "order": 4,
      "owner": "authorized_moderator",
      "mustCompleteBefore": "release_of_reviewed_content",
      "requiredInputs": ["safe evidence bundle", "policy version", "category ids", "reason codes", "prior decisions"],
      "allowedOutcomes": ["released", "rejected", "needs_more_context"],
      "failureDisposition": "remain_quarantined"
    },
    {
      "id": "appeal",
      "order": 5,
      "owner": "independent_authorized_reviewer",
      "mustCompleteBefore": "appeal_closeout",
      "requiredInputs": ["appeal id", "original decision", "user statement", "safe evidence bundle", "review history"],
      "allowedOutcomes": ["upheld", "overturned", "partially_overturned", "needs_more_information"],
      "failureDisposition": "original_decision_remains"
    }
  ],
