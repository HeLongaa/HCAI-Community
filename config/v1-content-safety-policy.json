  "dispositions": [
    {
      "id": "prohibited",
      "meaning": "The requested purpose or content is never eligible for generation or release in V1.",
      "providerDispatchAllowed": false,
      "providerDispatchAfterReviewAllowed": false,
      "outputReleaseAllowed": false,
      "requestAction": "reject",
      "outputAction": "quarantine_and_reject",
      "terminal": true,
      "appealEligible": true
    },
    {
      "id": "block",
      "meaning": "The request is disallowed as submitted, lacks required rights or context, or cannot be safely classified.",
      "providerDispatchAllowed": false,
      "providerDispatchAfterReviewAllowed": false,
      "outputReleaseAllowed": false,
      "requestAction": "block_before_dispatch",
      "outputAction": "quarantine",
      "terminal": false,
      "appealEligible": true
    },
    {
      "id": "review",
      "meaning": "A trained reviewer must decide using the recorded context before provider dispatch or output release.",
      "providerDispatchAllowed": false,
      "providerDispatchAfterReviewAllowed": true,
      "outputReleaseAllowed": false,
      "requestAction": "hold_for_review",
      "outputAction": "quarantine_for_review",
      "terminal": false,
      "appealEligible": true
    },
    {
      "id": "allow",
      "meaning": "The request may proceed only after all mandatory automated, rights, region, provider, and output checks pass.",
